    {
      "name": "3. Analytics & Dashboard",
      "item": [
        {
          "name": "Get Dashboard Summary",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Summary data is complete\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.have.property('users');",
                  "    pm.expect(jsonData.data).to.have.property('services');",
                  "    pm.expect(jsonData.data).to.have.property('data');",
                  "    pm.expect(jsonData.data).to.have.property('performance');",
                  "    pm.expect(jsonData.data).to.have.property('alerts');",
                  "});",
                  "",
                  "pm.test(\"User stats are correct\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.users).to.have.property('total');",
                  "    pm.expect(jsonData.data.users).to.have.property('active');",
                  "    pm.expect(jsonData.data.users).to.have.property('new');",
                  "});",
                  "",
                  "pm.test(\"Service stats are correct\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.services).to.have.property('total');",
                  "    pm.expect(jsonData.data.services).to.have.property('healthy');",
                  "});",
                  "",
                  "pm.test(\"Performance metrics are present\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.performance).to.have.property('avgCpuUsage');",
                  "    pm.expect(jsonData.data.performance).to.have.property('avgMemoryUsage');",
                  "    pm.expect(jsonData.data.performance).to.have.property('avgDiskUsage');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/analytics/summary?period=today",
              "host": ["{{base_url}}"],
              "path": ["api", "analytics", "summary"],
              "query": [
                {
                  "key": "period",
                  "value": "today",
                  "description": "today | week | month"
                }
              ]
            },
            "description": "Lấy tổng hợp thống kê cho dashboard.\n\n**Metrics included:**\n- **Users:** total, active, new registrations\n- **Services:** total, status distribution (healthy/degraded/down)\n- **Data:** files count, queries count, storage usage\n- **Performance:** CPU, Memory, Disk usage averages\n- **Alerts:** active alerts count\n- **Recent activities:** latest uploads & queries\n\n**Period options:**\n- `today`: Từ 00:00 hôm nay\n- `week`: 7 ngày gần nhất\n- `month`: 30 ngày gần nhất"
          },
