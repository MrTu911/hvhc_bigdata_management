                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"queryText\": \"SELECT event_date, COUNT(*) as total FROM events WHERE event_date >= today() - 7 GROUP BY event_date ORDER BY event_date DESC\",\n  \"queryType\": \"CLICKHOUSE\",\n  \"department\": \"Khoa Công nghệ Thông tin\",\n  \"parameters\": {\n    \"database\": \"analytics\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/data/query",
              "host": ["{{base_url}}"],
              "path": ["api", "data", "query"]
            },
            "description": "Thực thi query trên ClickHouse analytics database.\n\n**Use cases:**\n- Time-series analytics\n- Log analysis\n- Real-time reporting\n- Large dataset aggregations"
          },
          "response": []
        },
