// ===============================================
// BHXH - Bảo hiểm Xã hội Extended Models
// ===============================================

// Yêu cầu chế độ bảo hiểm
model InsuranceClaim {
  id               String               @id @default(cuid())
  insuranceInfoId  String
  claimType        InsuranceClaimType
  status           InsuranceClaimStatus @default(PENDING)
  amount           Decimal?             @db.Decimal(15, 2)
  calculatedAmount Decimal?             @db.Decimal(15, 2)
  benefitDays      Int? // Số ngày hưởng
  startDate        DateTime? // Ngày bắt đầu hưởng
  endDate          DateTime? // Ngày kết thúc hưởng
  reason           String?              @db.Text
  description      String?              @db.Text
  documentNumber   String? // Số quyết định
  documentDate     DateTime?
  hospitalName     String? // Cơ sở y tế
  diagnosisCode    String? // Mã ICD
  diagnosis        String? // Chẩn đoán
  attachments      String[] // Danh sách file đính kèm
  submittedAt      DateTime?
  submittedBy      String?
  reviewedAt       DateTime?
  reviewedBy       String?
  approvedAt       DateTime?
  approvedBy       String?
  rejectedAt       DateTime?
  rejectedBy       String?
  rejectReason     String?
  paidAt           DateTime?
  paidBy           String?
  paymentReference String? // Số chứng từ chi
  notes            String?              @db.Text
  deletedAt        DateTime?
  deletedBy        String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  insuranceInfo    InsuranceInfo        @relation(fields: [insuranceInfoId], references: [id], onDelete: Cascade)

  @@index([insuranceInfoId])
  @@index([claimType])
  @@index([status])
  @@index([startDate])
  @@index([deletedAt])
  @@map("insurance_claims")
}

// Cơ sở khám chữa bệnh ban đầu
model MedicalFacility {
  id                String              @id @default(cuid())
  code              String              @unique
  name              String
  type              MedicalFacilityType
  address           String?
  province          String?
  district          String?
  phone             String?
  level             Int?                @default(1) // 1,2,3,4 theo tuyến
  isActive          Boolean             @default(true)
  contractStartDate DateTime?
  contractEndDate   DateTime?
  notes             String?
  deletedAt         DateTime?
  deletedBy         String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([type])
  @@index([province])
  @@index([isActive])
  @@map("medical_facilities")
}

// Bảng lương quân đội theo cấp bậc (để tính đóng BHXH)
model MilitarySalaryGrade {
  id                String    @id @default(cuid())
  rank              String // Cấp bậc
  rankCode          String    @unique
  baseSalary        Decimal   @db.Decimal(15, 2) // Lương cơ bản
  rankAllowance     Decimal?  @db.Decimal(15, 2) // Phụ cấp quân hàm
  positionAllowance Decimal?  @db.Decimal(15, 2) // Phụ cấp chức vụ
  seniorityRate     Decimal?  @db.Decimal(5, 3) // Tỷ lệ phụ cấp thâm niên/năm
  insuranceRate     Decimal   @default(0.105) @db.Decimal(5, 3) // Tỷ lệ đóng BHXH (10.5%)
  healthInsRate     Decimal   @default(0.045) @db.Decimal(5, 3) // Tỷ lệ đóng BHYT (4.5%)
  unemploymentRate  Decimal   @default(0.01) @db.Decimal(5, 3) // Tỷ lệ đóng BHTN (1%)
  effectiveDate     DateTime  @default(now())
  expiryDate        DateTime?
  isActive          Boolean   @default(true)
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([rankCode])
  @@index([isActive])
  @@map("military_salary_grades")
}

enum InsuranceClaimType {
  SICK_LEAVE // Ốm đau
  MATERNITY // Thai sản
  OCCUPATIONAL_DISEASE // Bệnh nghề nghiệp
  WORK_ACCIDENT // Tai nạn lao động
  RETIREMENT // Hưu trí
  SURVIVORSHIP // Tử tuất
  UNEMPLOYMENT // Thất nghiệp
  MEDICAL_EXPENSE // Chi phí khám chữa bệnh
  OTHER
}

enum InsuranceClaimStatus {
  DRAFT // Nháp
  PENDING // Chờ duyệt
  UNDER_REVIEW // Đang xét duyệt
  APPROVED // Đã duyệt
  REJECTED // Từ chối
  PAID // Đã chi trả
  CANCELLED // Đã hủy
}

enum MedicalFacilityType {
  MILITARY_HOSPITAL // Bệnh viện quân đội
  CENTRAL_HOSPITAL // Bệnh viện TW
  PROVINCIAL_HOSPITAL // Bệnh viện tỉnh
  DISTRICT_HOSPITAL // Bệnh viện huyện
  CLINIC // Phòng khám
  HEALTH_CENTER // Trạm y tế
  OTHER
}

// ===== PHASE 2 & 3: KHẢO THÍ, HỌC LIỆU, PHÒNG THÍ NGHIỆM =====

// Kế hoạch thi
model ExamPlan {
  id                   String         @id @default(cuid())
  code                 String         @unique // e.g., "KHT-HK1-2025"
  name                 String // e.g., "Kế hoạch thi HK1 2025-2026"
  termId               String
  examType             ExamPlanType   @default(FINAL)
  startDate            DateTime
  endDate              DateTime
  registrationDeadline DateTime?
  description          String?
  rules                String? // Quy định thi
  status               ExamPlanStatus @default(DRAFT)
  isPublished          Boolean        @default(false)
  publishedAt          DateTime?
  createdBy            String?
  approvedBy           String?
  approvedAt           DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  term                 Term           @relation(fields: [termId], references: [id])
  examSessions         ExamSession[]

  @@index([termId])
  @@index([examType])
  @@index([status])
  @@map("exam_plans")
}

// Ca thi
model ExamSession {
  id                String             @id @default(cuid())
  code              String             @unique // e.g., "CA-001-20250615"
  examPlanId        String
  classSectionId    String? // Lớp học phần thi
  subjectCode       String? // Mã môn
  subjectName       String? // Tên môn
  examDate          DateTime
  startTime         String // "07:00"
  endTime           String // "09:30"
  duration          Int                @default(90) // Phút
  roomId            String?
  maxStudents       Int                @default(50)
  registeredCount   Int                @default(0)
  supervisorId      String? // Cán bộ coi thi chính
  assistantIds      String[]           @default([]) // Cán bộ phụ
  examFormat        ExamFormat         @default(WRITTEN)
  status            ExamSessionStatus  @default(SCHEDULED)
  instructions      String?
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  examPlan          ExamPlan           @relation(fields: [examPlanId], references: [id], onDelete: Cascade)
  room              Room?              @relation("ExamSessionRoom", fields: [roomId], references: [id])
  examRegistrations ExamRegistration[]

  @@index([examPlanId])
  @@index([examDate])
  @@index([roomId])
  @@index([status])
  @@map("exam_sessions")
}

// Đăng ký thi
model ExamRegistration {
  id            String        @id @default(cuid())
  examSessionId String
  hocVienId     String
  seatNumber    String? // Số báo danh
  status        ExamRegStatus @default(REGISTERED)
  checkInTime   DateTime?
  score         Float?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  examSession   ExamSession   @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
  hocVien       HocVien       @relation(fields: [hocVienId], references: [id], onDelete: Cascade)

  @@unique([examSessionId, hocVienId])
  @@index([examSessionId])
  @@index([hocVienId])
  @@index([status])
  @@map("exam_registrations")
}

// Ngân hàng câu hỏi
model QuestionBank {
  id             String     @id @default(cuid())
  code           String     @unique // e.g., "NHC-TH001"
  name           String // e.g., "NH câu hỏi môn Tin học đại cương"
  subjectCode    String
  subjectName    String
  unitId         String? // Khoa quản lý
  description    String?
  totalQuestions Int        @default(0)
  isActive       Boolean    @default(true)
  isPublic       Boolean    @default(false)
  createdBy      String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  unit           Unit?      @relation(fields: [unitId], references: [id])
  questions      Question[]

  @@index([subjectCode])
  @@index([unitId])
  @@map("question_banks")
}

// Câu hỏi
model Question {
  id              String              @id @default(cuid())
  questionBankId  String
  code            String // e.g., "TH001-001"
  content         String              @db.Text // Nội dung câu hỏi
  contentType     QuestionContentType @default(TEXT)
  questionType    QuestionType        @default(MULTIPLE_CHOICE)
  options         Json? // Đáp án (cho trắc nghiệm)
  correctAnswer   String? // Đáp án đúng
  explanation     String?             @db.Text // Giải thích
  difficulty      DifficultyLevel     @default(MEDIUM)
  points          Float               @default(1)
  chapter         String? // Chương
  topic           String? // Chủ đề
  learningOutcome String? // Chuẩn đầu ra
  tags            String[]            @default([])
  usageCount      Int                 @default(0)
  avgScore        Float? // Điểm TB khi sử dụng
  status          QuestionStatus      @default(ACTIVE)
  isActive        Boolean             @default(true)
  createdBy       String?
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  questionBank    QuestionBank        @relation(fields: [questionBankId], references: [id], onDelete: Cascade)

  @@unique([questionBankId, code])
  @@index([questionBankId])
  @@index([difficulty])
  @@index([questionType])
  @@index([chapter])
  @@map("questions")
}

// Học liệu
model LearningMaterial {
  id            String              @id @default(cuid())
  code          String              @unique // e.g., "HL-TH001-001"
  title         String
  description   String?
  subjectCode   String?
  subjectName   String?
  materialType  MaterialType        @default(DOCUMENT)
  format        String? // pdf, docx, pptx, mp4...
  fileUrl       String? // Cloud storage path
  fileName      String?
  fileSize      Int? // bytes
  duration      Int? // Phút (cho video/audio)
  thumbnailUrl  String?
  unitId        String? // Khoa quản lý
  authorId      String? // Tác giả/Upload by
  version       String              @default("1.0")
  chapter       String?
  topic         String?
  tags          String[]            @default([])
  viewCount     Int                 @default(0)
  downloadCount Int                 @default(0)
  rating        Float?
  ratingCount   Int                 @default(0)
  accessLevel   MaterialAccessLevel @default(INTERNAL)
  isActive      Boolean             @default(true)
  publishedAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  unit          Unit?               @relation(fields: [unitId], references: [id])

  @@index([subjectCode])
  @@index([materialType])
  @@index([unitId])
  @@index([authorId])
  @@map("learning_materials")
}

// Phòng thí nghiệm
model Lab {
  id            String         @id @default(cuid())
  code          String         @unique // e.g., "PTN-CNTT-01"
  name          String // e.g., "PTN Mạng máy tính"
  labType       LabType        @default(COMPUTER)
  building      String?
  floor         Int?
  roomNumber    String?
  capacity      Int            @default(30)
  area          Float? // m2
  unitId        String? // Khoa quản lý
  managerId     String? // Người quản lý
  description   String?
  regulations   String? // Nội quy
  equipment     String?        @db.Text // Danh sách thiết bị
  status        LabStatus      @default(AVAILABLE)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  unit          Unit?          @relation(fields: [unitId], references: [id])
  labEquipments LabEquipment[]
  labSessions   LabSession[]

  @@index([labType])
  @@index([unitId])
  @@index([status])
  @@map("labs")
}

// Thiết bị phòng thí nghiệm
model LabEquipment {
  id                  String                 @id @default(cuid())
  code                String                 @unique // e.g., "TB-PC-001"
  name                String
  labId               String
  equipmentType       EquipmentType          @default(COMPUTER)
  brand               String?
  model               String?
  serialNumber        String?
  purchaseDate        DateTime?
  warrantyExpiry      DateTime?
  purchasePrice       Decimal?               @db.Decimal(15, 2)
  currentValue        Decimal?               @db.Decimal(15, 2)
  specifications      Json? // Cấu hình chi tiết
  location            String? // Vị trí trong PTN
  status              EquipmentStatus        @default(OPERATIONAL)
  condition           EquipmentCondition     @default(GOOD)
  lastMaintenanceDate DateTime?
  nextMaintenanceDate DateTime?
  maintenanceNotes    String?
  notes               String?
  isActive            Boolean                @default(true)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  lab                 Lab                    @relation(fields: [labId], references: [id], onDelete: Cascade)
  maintenanceLogs     EquipmentMaintenance[]

  @@index([labId])
  @@index([equipmentType])
  @@index([status])
  @@map("lab_equipments")
}

// Lịch sử bảo trì thiết bị
model EquipmentMaintenance {
  id              String            @id @default(cuid())
  equipmentId     String
  maintenanceType MaintenanceType   @default(ROUTINE)
  performedDate   DateTime
  performedBy     String?
  description     String?
  cost            Decimal?          @db.Decimal(15, 2)
  findings        String?
  actions         String?
  partsReplaced   String?
  nextScheduled   DateTime?
  status          MaintenanceStatus @default(COMPLETED)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  equipment       LabEquipment      @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
  @@index([performedDate])
  @@map("equipment_maintenances")
}

// Buổi thực hành PTN
model LabSession {
  id              String           @id @default(cuid())
  code            String           @unique // e.g., "TH-PTN-001"
  labId           String
  classSectionId  String?
  sessionDate     DateTime
  startTime       String // "07:00"
  endTime         String // "09:30"
  topic           String?
  description     String?
  supervisorId    String?
  maxStudents     Int              @default(30)
  registeredCount Int              @default(0)
  status          LabSessionStatus @default(SCHEDULED)
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  lab             Lab              @relation(fields: [labId], references: [id])

  @@index([labId])
  @@index([sessionDate])
  @@index([status])
  @@map("lab_sessions")
}

// Thống kê giảng dạy tổng hợp (lưu cache để truy vấn nhanh)
model TeachingStatistics {
  id                String   @id @default(cuid())
  facultyId         String
  termId            String?
  academicYearId    String?
  totalCourses      Int      @default(0)
  totalSessions     Int      @default(0)
  totalStudents     Int      @default(0)
  avgAttendanceRate Float?
  avgPassRate       Float?
  avgGrade          Float?
  totalHours        Int      @default(0)
  evaluationScore   Float? // Điểm đánh giá GV
  evaluationCount   Int      @default(0)
  notes             String?
  calculatedAt      DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([facultyId, termId])
  @@index([facultyId])
  @@index([termId])
  @@index([academicYearId])
  @@map("teaching_statistics")
}

// ===== ENUMS FOR PHASE 2 & 3 =====

enum ExamPlanType {
  MIDTERM // Giữa kỳ
  FINAL // Cuối kỳ
  SUPPLEMENTARY // Thi lại/phụ
  MAKEUP // Thi bù
  ENTRANCE // Tuyển sinh
  GRADUATION // Tốt nghiệp
}

enum ExamPlanStatus {
  DRAFT // Nháp
  PENDING // Chờ duyệt
  APPROVED // Đã duyệt
  PUBLISHED // Đã công bố
  ONGOING // Đang diễn ra
  COMPLETED // Hoàn thành
  CANCELLED // Hủy bỏ
}

enum ExamFormat {
  WRITTEN // Tự luận
  MULTIPLE_CHOICE // Trắc nghiệm
  ORAL // Vấn đáp
  PRACTICAL // Thực hành
  PROJECT // Đồ án
  MIXED // Kết hợp
}

enum ExamSessionStatus {
  SCHEDULED // Đã lên lịch
  ONGOING // Đang diễn ra
  COMPLETED // Hoàn thành
  CANCELLED // Hủy
  POSTPONED // Hoãn
}

enum ExamRegStatus {
  REGISTERED // Đã đăng ký
  CONFIRMED // Đã xác nhận
  CHECKED_IN // Đã điểm danh
  COMPLETED // Đã thi xong
  ABSENT // Vắng
  DISQUALIFIED // Bị đình chỉ
}

enum QuestionContentType {
  TEXT // Văn bản thuần
  RICH_TEXT // Văn bản có định dạng
  IMAGE // Có hình ảnh
  AUDIO // Có âm thanh
  VIDEO // Có video
}

enum QuestionType {
  MULTIPLE_CHOICE // Trắc nghiệm nhiều lựa chọn
  SINGLE_CHOICE // Trắc nghiệm một đáp án
  TRUE_FALSE // Đúng/Sai
  FILL_BLANK // Điền khuyết
  MATCHING // Nối cặp
  ESSAY // Tự luận ngắn
  LONG_ESSAY // Tự luận dài
  CALCULATION // Bài toán
  CODE // Viết code
}

enum DifficultyLevel {
  VERY_EASY // Rất dễ
  EASY // Dễ
  MEDIUM // Trung bình
  HARD // Khó
  VERY_HARD // Rất khó
}

enum QuestionStatus {
  DRAFT // Nháp
  ACTIVE // Sử dụng
  REVIEW // Cần xem xét
  DEPRECATED // Không còn dùng
}

enum MaterialType {
  DOCUMENT // Tài liệu (PDF, Word)
  PRESENTATION // Slide (PPT)
  VIDEO // Video bài giảng
  AUDIO // Audio
  IMAGE // Hình ảnh
  SPREADSHEET // Bảng tính
  CODE // Mã nguồn
  INTERACTIVE // Tương tác
  LINK // Liên kết
  OTHER // Khác
}

enum MaterialAccessLevel {
  PUBLIC // Công khai
  INTERNAL // Nội bộ
  RESTRICTED // Hạn chế
  PRIVATE // Riêng tư
}

enum LabType {
  COMPUTER // PTN Tin học
  PHYSICS // PTN Vật lý
  CHEMISTRY // PTN Hóa học
  BIOLOGY // PTN Sinh học
  ELECTRONICS // PTN Điện tử
  MECHANICAL // PTN Cơ khí
  SIMULATION // PTN Mô phỏng
  LANGUAGE // PTN Ngoại ngữ
  MILITARY // PTN Quân sự
  OTHER // Khác
}

enum LabStatus {
  AVAILABLE // Sẵn sàng
  OCCUPIED // Đang sử dụng
  MAINTENANCE // Bảo trì
  CLOSED // Đóng cửa
}

enum EquipmentType {
  COMPUTER // Máy tính
  SERVER // Máy chủ
  NETWORK // Thiết bị mạng
  PROJECTOR // Máy chiếu
  PRINTER // Máy in
  SCANNER // Máy scan
  CAMERA // Camera
  AUDIO // Thiết bị âm thanh
  LAB_INSTRUMENT // Dụng cụ thí nghiệm
  MEASURING // Thiết bị đo
  MILITARY_EQUIP // Trang thiết bị QS
  FURNITURE // Nội thất
  OTHER // Khác
}

enum EquipmentStatus {
  OPERATIONAL // Hoạt động tốt
  DEGRADED // Giảm hiệu năng
  UNDER_REPAIR // Đang sửa chữa
  OUT_OF_SERVICE // Ngừng hoạt động
  RETIRED // Thanh lý
}

enum EquipmentCondition {
  EXCELLENT // Xuất sắc
  GOOD // Tốt
  FAIR // Khá
  POOR // Kém
  CRITICAL // Nghiêm trọng
}

enum MaintenanceType {
  ROUTINE // Định kỳ
  REPAIR // Sửa chữa
  UPGRADE // Nâng cấp
  INSPECTION // Kiểm tra
  CALIBRATION // Hiệu chuẩn
}

enum MaintenanceStatus {
  SCHEDULED // Đã lên lịch
  IN_PROGRESS // Đang thực hiện
  COMPLETED // Hoàn thành
  CANCELLED // Hủy bỏ
}

enum LabSessionStatus {
  SCHEDULED // Đã lên lịch
  ONGOING // Đang diễn ra
  COMPLETED // Hoàn thành
  CANCELLED // Hủy
}

// ============================================
// DANH MỤC DÙNG CHUNG (MASTER DATA)
// ============================================

// Dân tộc
model Ethnicity {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users     User[]      @relation("UserEthnicity")
  personnel Personnel[] @relation("PersonnelEthnicity")

  @@index([code])
  @@map("ethnicities")
}

// Tôn giáo
model Religion {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users     User[]      @relation("UserReligion")
  personnel Personnel[] @relation("PersonnelReligion")

  @@index([code])
  @@map("religions")
}

// Chuyên ngành/Lĩnh vực đào tạo
model SpecializationCatalog {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  parentId    String?
  level       Int      @default(1) // 1: Lĩnh vực, 2: Ngành, 3: Chuyên ngành
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent    SpecializationCatalog?  @relation("SpecializationHierarchy", fields: [parentId], references: [id])
  children  SpecializationCatalog[] @relation("SpecializationHierarchy")
  users     User[]                  @relation("UserSpecialization")
  personnel Personnel[]             @relation("PersonnelSpecialization")
  students  HocVien[]               @relation("StudentMajor")
  classes   StudentClass[]          @relation("ClassMajor")

  @@index([code])
  @@index([parentId])
  @@map("specialization_catalogs")
}

// Đơn vị hành chính (Tỉnh/Huyện/Xã)
model AdministrativeUnit {
  id        String              @id @default(cuid())
  code      String              @unique // Mã đơn vị hành chính (theo Tổng cục Thống kê)
  name      String
  fullName  String?
  level     AdministrativeLevel
  parentId  String?
  sortOrder Int                 @default(0)
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  parent                 AdministrativeUnit?  @relation("AdminUnitHierarchy", fields: [parentId], references: [id])
  children               AdministrativeUnit[] @relation("AdminUnitHierarchy")
  usersBirthPlace        User[]               @relation("UserBirthPlace")
  usersPlaceOfOrigin     User[]               @relation("UserPlaceOfOrigin")
  personnelBirthPlace    Personnel[]          @relation("PersonnelBirthPlaceAdmin")
  personnelPlaceOfOrigin Personnel[]          @relation("PersonnelPlaceOfOriginAdmin")

  @@index([code])
  @@index([parentId])
  @@index([level])
  @@map("administrative_units")
}

enum AdministrativeLevel {
  PROVINCE // Tỉnh/Thành phố
  DISTRICT // Quận/Huyện
  WARD // Phường/Xã
}

// Khóa học (cho Student)
model Cohort {
  id          String   @id @default(cuid())
  code        String   @unique // K60, K61, ...
  name        String // Khóa 60, Khóa 61, ...
  startYear   Int
  endYear     Int?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  students HocVien[]
  classes  StudentClass[]

  @@index([code])
  @@map("cohorts")
}

// Lớp học (cho Student)
model StudentClass {
  id          String   @id @default(cuid())
  code        String   @unique // K60A, K60B, ...
  name        String
  cohortId    String
  majorId     String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cohort   Cohort                 @relation(fields: [cohortId], references: [id])
  major    SpecializationCatalog? @relation("ClassMajor", fields: [majorId], references: [id])
  students HocVien[]

  @@index([cohortId])
  @@index([majorId])
  @@map("student_classes")
}
