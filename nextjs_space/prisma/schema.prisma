// M10 – UC-52: Phiên bản chương trình đào tạo (CRITICAL – bắt buộc trước go-live)
model ProgramVersion {
  id                  String               @id @default(cuid())
  programId           String
  versionCode         String
  effectiveFromCohort String // khóa áp dụng, ví dụ: "K45", "2023"
  totalCredits        Int?
  requiredCoursesJson Json? // khung học phần dạng JSON
  status              ProgramVersionStatus @default(DRAFT)
  notes               String?
  createdBy           String?
  approvedBy          String?
  approvedAt          DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  program         Program          @relation(fields: [programId], references: [id])
  hocViens        HocVien[]
  curriculumPlans CurriculumPlan[]

  @@unique([programId, versionCode])
  @@index([programId])
  @@index([status])
  @@index([effectiveFromCohort])
  @@map("program_versions")
}

// M10 – UC-53: Kế hoạch đào tạo học kỳ / năm học (= SemesterPlan trong design M10)
model CurriculumPlan {
  id               String             @id @default(cuid())
  code             String             @unique
  name             String
  programId        String
  programVersionId String? // M10: gắn với phiên bản CTĐT cụ thể
  academicYearId   String?
  cohort           String?
  totalCredits     Int                @default(120)
  version          String             @default("1.0")
  status           CurriculumStatus   @default(DRAFT)
  notes            String?
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  createdBy        String?
  approvedBy       String?
  approvedAt       DateTime?
  courses          CurriculumCourse[]
  academicYear     AcademicYear?      @relation(fields: [academicYearId], references: [id])
  program          Program            @relation(fields: [programId], references: [id])
  programVersion   ProgramVersion?    @relation(fields: [programVersionId], references: [id])

  @@index([programId])
  @@index([programVersionId])
  @@index([academicYearId])
  @@index([cohort])
  @@index([status])
  @@map("curriculum_plans")
}

