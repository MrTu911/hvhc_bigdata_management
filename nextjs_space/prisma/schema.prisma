  // M10 – UC-56: Grade fields (ClassEnrollment = GradeRecord)
  attendanceScore Float? // điểm chuyên cần
  assignmentScore Float? // điểm thực hành / bài tập
  midtermScore    Float?
  finalScore      Float?
  totalScore      Float?
  passFlag        Boolean? // đạt / không đạt (tính tự động hoặc ghi rõ)
  letterGrade     String?
