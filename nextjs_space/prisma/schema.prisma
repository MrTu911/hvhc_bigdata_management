// M10 – UC-59: Khóa luận / Luận văn / Đồ án
enum ThesisStatus {
  DRAFT
  IN_PROGRESS
  DEFENDED
  ARCHIVED
}

// M10 – UC-60: Trạng thái xét tốt nghiệp
enum GraduationAuditStatus {
  PENDING // Chờ xét
  ELIGIBLE // Đủ điều kiện
  INELIGIBLE // Chưa đủ điều kiện
  APPROVED // Đã duyệt tốt nghiệp
  REJECTED // Từ chối
}

/**
 * M10 – UC-59: Quản lý khóa luận / luận văn / đồ án
 */
model ThesisProject {
  id                String       @id @default(cuid())
  hocVienId         String
  thesisType        String // khoa_luan / luan_van / luan_an / do_an
  title             String
  titleEn           String?
  advisorId         String? // FK FacultyProfile – giảng viên hướng dẫn
  reviewerId        String? // FK FacultyProfile – phản biện
  defenseDate       DateTime?
  defenseScore      Float?
  status            ThesisStatus @default(DRAFT)
  repositoryFileUrl String? // URL file lưu trữ (MinIO)
  abstractText      String?
  keywords          String?
  notes             String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  createdBy         String?

  hocVien  HocVien         @relation(fields: [hocVienId], references: [id], onDelete: Cascade)
  advisor  FacultyProfile? @relation("ThesisAdvisor", fields: [advisorId], references: [id])
  reviewer FacultyProfile? @relation("ThesisReviewer", fields: [reviewerId], references: [id])

  @@index([hocVienId])
  @@index([status])
  @@index([defenseDate])
  @@index([advisorId])
  @@map("thesis_projects")
}

/**
 * M10 – UC-60: Kết quả xét tốt nghiệp (Graduation Rule Engine output)
 * UAT bắt buộc trước go-live – xem module-m10-thesis-graduation-dashboard.md
 */
model GraduationAudit {
  id                 String                @id @default(cuid())
  hocVienId          String
  auditDate          DateTime
  totalCreditsEarned Int?
  gpa                Float?
  conductEligible    Boolean               @default(false)
  thesisEligible     Boolean               @default(false)
  languageEligible   Boolean               @default(false)
  graduationEligible Boolean               @default(false)
  failureReasonsJson Json? // [{ code, message }]
  status             GraduationAuditStatus @default(PENDING)
  decisionNo         String?
  approvedBy         String?
  approvedAt         DateTime?
  notes              String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  createdBy          String?

  hocVien       HocVien        @relation(fields: [hocVienId], references: [id], onDelete: Cascade)
  diplomaRecord DiplomaRecord?

  @@index([hocVienId])
  @@index([status])
  @@index([auditDate])
  @@index([graduationEligible])
  @@map("graduation_audits")
}

/**
 * M10 – UC-60: Văn bằng / Chứng chỉ đã cấp
 */
model DiplomaRecord {
  id                String    @id @default(cuid())
  hocVienId         String
  graduationAuditId String?   @unique
  diplomaNo         String?   @unique
  diplomaType       String // dai_hoc / thac_si / tien_si / chung_chi / ...
  classification    String? // Xuất sắc / Giỏi / Khá / Trung bình
  graduationDate    DateTime?
  issuedAt          DateTime?
  issuedBy          String?
  fileUrl           String? // MinIO
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  hocVien         HocVien          @relation(fields: [hocVienId], references: [id], onDelete: Cascade)
  graduationAudit GraduationAudit? @relation(fields: [graduationAuditId], references: [id])

  @@index([hocVienId])
  @@index([diplomaNo])
  @@index([graduationDate])
  @@map("diploma_records")
}

/**
 * M10 – UC-61: Kho tra cứu học vụ & hồ sơ đào tạo
 */
model AcademicRepositoryItem {
  id           String   @id @default(cuid())
  hocVienId    String? // optional – có thể là tài liệu chung
  itemType     String // transcript / thesis / dossier / certificate / other
  title        String
  fileUrl      String?
  metadataJson Json? // { academicYear, semesterCode, programCode, ... }
  isPublic     Boolean  @default(false)
  indexedAt    DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String?

  hocVien HocVien? @relation(fields: [hocVienId], references: [id], onDelete: SetNull)

  @@index([hocVienId])
  @@index([itemType])
  @@index([indexedAt])
  @@map("academic_repository_items")
}

// =============================================================================
// MODULE M13 – WORKFLOW ENGINE (Phase 1)
// Workflow platform dùng chung cho toàn hệ thống.
// M13 chỉ giữ trạng thái, hành động, lịch sử, chữ ký, thông báo.
// Dữ liệu nghiệp vụ gốc vẫn thuộc module chủ quản (entityType + entityId).
// =============================================================================

/**
 * M13 – Definition layer
 * Template định nghĩa quy trình, có thể tái sử dụng cho nhiều module.
 * code phải unique toàn hệ thống, dùng làm key tra cứu khi khởi tạo workflow.
 */
model WorkflowTemplate {
  id          String   @id @default(cuid())
  code        String   @unique @db.VarChar(80)
  name        String   @db.VarChar(200)
  moduleKey   String   @db.VarChar(10) // "M03" | "M05" | "M09" | "M10" | ...
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdBy   String   @db.VarChar(36)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  versions WorkflowTemplateVersion[]

  @@index([moduleKey])
  @@index([isActive])
  @@map("wf_templates")
}

/**
 * M13 – Version của template.
 * Chỉ một version PUBLISHED tại một thời điểm.
 * Workflow instance đang chạy giữ nguyên versionId tại lúc khởi tạo.
 */
model WorkflowTemplateVersion {
  id             String                @id @default(cuid())
  templateId     String
  versionNo      Int                   @db.SmallInt
  status         WorkflowVersionStatus @default(DRAFT)
  publishedAt    DateTime?
  publishedBy    String?               @db.VarChar(36)
  definitionJson Json? // cached snapshot toàn bộ definition
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  template    WorkflowTemplate             @relation(fields: [templateId], references: [id], onDelete: Cascade)
  steps       WorkflowStepTemplate[]
  transitions WorkflowTransitionTemplate[]
  instances   WorkflowInstance[]

  @@unique([templateId, versionNo])
  @@index([templateId, status])
  @@map("wf_template_versions")
}

/**
 * M13 – Step định nghĩa trong một version.
 * stepType xác định loại bước: START / TASK / APPROVAL / SIGNATURE / END.
 * requiresSignature = true thì bước đó mới mở hành vi ký số.
 */
model WorkflowStepTemplate {
  id                String           @id @default(cuid())
  templateVersionId String
  code              String           @db.VarChar(60) // unique trong phạm vi version
  name              String           @db.VarChar(200)
  stepType          WorkflowStepType
  orderIndex        Int              @db.SmallInt
  slaHours          Int?             @db.SmallInt
  isParallel        Boolean          @default(false)
  requiresSignature Boolean          @default(false)
  configJson        Json? // approver policy, notification policy...

  templateVersion WorkflowTemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Cascade)

  @@unique([templateVersionId, code])
  @@index([templateVersionId])
  @@map("wf_step_templates")
}

/**
 * M13 – Transition định nghĩa: từ bước nào + action nào → đến bước nào.
 * conditionExpression là biểu thức có kiểm soát, không cho nhúng code tùy ý.
 * priority dùng khi có nhiều transition cùng fromStep + action.
 */
model WorkflowTransitionTemplate {
  id                  String  @id @default(cuid())
  templateVersionId   String
  fromStepCode        String  @db.VarChar(60)
  actionCode          String  @db.VarChar(40) // APPROVE | REJECT | RETURN | ...
  toStepCode          String  @db.VarChar(60)
  conditionExpression String? @db.VarChar(500)
  priority            Int     @default(0) @db.SmallInt

  templateVersion WorkflowTemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Cascade)

  @@index([templateVersionId, fromStepCode])
  @@map("wf_transition_templates")
}

// =============================================================================
// M13 – Runtime layer
// =============================================================================

/**
 * M13 – Instance của một quy trình thực tế đang chạy.
 * entityType + entityId trỏ về dữ liệu gốc của module chủ quản.
 * M13 không duplicate hay thay thế dữ liệu đó.
 */
model WorkflowInstance {
  id                String                 @id @default(cuid())
  templateId        String
  templateVersionId String
  entityType        String                 @db.VarChar(80) // "PolicyRecord" | "ResearchProject" | ...
  entityId          String                 @db.VarChar(36)
  title             String                 @db.VarChar(300)
  summary           String?                @db.Text
  status            WorkflowInstanceStatus @default(DRAFT)
  currentStepCode   String?                @db.VarChar(60)
  initiatorId       String                 @db.VarChar(36)
  currentAssigneeId String?                @db.VarChar(36) // nullable nếu parallel/multi
  priority          Int                    @default(0) @db.SmallInt
  startedAt         DateTime               @default(now())
  completedAt       DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  templateVersion WorkflowTemplateVersion @relation(fields: [templateVersionId], references: [id])
  steps           WorkflowStepInstance[]
  actions         WorkflowAction[]
  signatures      WorkflowSignature[]
  notifications   WorkflowNotification[]
  escalations     WorkflowEscalation[]
  auditLogs       WorkflowAuditLog[]

  // Indexes cho dashboard, task inbox, entity lookup
  @@index([status])
  @@index([initiatorId])
  @@index([currentAssigneeId])
  @@index([entityType, entityId])
  @@index([templateId, status])
  @@index([startedAt])
  @@map("wf_instances")
}

/**
 * M13 – Step instance trong một quy trình đang chạy.
 * Mỗi bước được xử lý tạo ra một record riêng (history toàn bộ các bước).
 * dueAt dùng để tính SLA, overdue, reminder.
 */
model WorkflowStepInstance {
  id                 String             @id @default(cuid())
  workflowInstanceId String
  stepCode           String             @db.VarChar(60)
  status             WorkflowStepStatus @default(WAITING)
  assigneeId         String?            @db.VarChar(36)
  assignedAt         DateTime?
  startedAt          DateTime?
  actedAt            DateTime?
  dueAt              DateTime?
  completedAt        DateTime?

  workflowInstance WorkflowInstance @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)
  actions          WorkflowAction[]

  // Indexes cho task inbox (assigneeId + status) và overdue check (dueAt)
  @@index([workflowInstanceId])
  @@index([assigneeId, status])
  @@index([dueAt, status])
  @@map("wf_step_instances")
}

/**
 * M13 – Ghi nhận từng hành động người dùng hoặc hệ thống thực hiện.
 * Là nguồn sự thật cho lịch sử thao tác và audit trail.
 * actionCode theo enum WorkflowActionCode để tránh magic string.
 */
model WorkflowAction {
  id                 String             @id @default(cuid())
  workflowInstanceId String
  stepInstanceId     String
  actionCode         WorkflowActionCode
  actionBy           String             @db.VarChar(36)
  actionAt           DateTime           @default(now())
  comment            String?            @db.Text
  payloadJson        Json?

  workflowInstance WorkflowInstance     @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)
  stepInstance     WorkflowStepInstance @relation(fields: [stepInstanceId], references: [id])
  actor            User                 @relation("WorkflowActionActor", fields: [actionBy], references: [id])

  @@index([workflowInstanceId])
  @@index([actionBy])
  @@index([actionAt])
  @@map("wf_actions")
}

// =============================================================================
// M13 – Signature, Notification, Escalation, Audit
// =============================================================================

/**
 * M13 – Chữ ký số điện tử tại một bước yêu cầu ký.
 * Thiết kế theo adapter pattern: providerCode xác định nhà cung cấp.
 * hashValue + certificateInfoJson là bằng chứng kiểm tra về sau.
 */
model WorkflowSignature {
  id                  String                  @id @default(cuid())
  workflowInstanceId  String
  stepInstanceId      String
  signerId            String                  @db.VarChar(36)
  signatureType       String                  @db.VarChar(40) // lookup M19
  providerCode        String?                 @db.VarChar(40)
  signedAt            DateTime?
  status              WorkflowSignatureStatus @default(PENDING)
  certificateInfoJson Json?
  evidenceFileId      String?                 @db.VarChar(36) // MinIO fileId
  hashValue           String?                 @db.VarChar(500)

  workflowInstance WorkflowInstance @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)

  @@index([workflowInstanceId])
  @@index([signerId])
  @@map("wf_signatures")
}

/**
 * M13 – Thông báo gửi đến người dùng liên quan đến workflow.
 * channel: IN_APP (Phase 1), EMAIL / SMS (Phase 2).
 * readAt null = chưa đọc → dùng cho badge count ở UI.
 */
model WorkflowNotification {
  id                 String    @id @default(cuid())
  workflowInstanceId String
  recipientId        String    @db.VarChar(36)
  channel            String    @default("IN_APP") @db.VarChar(20) // IN_APP | EMAIL | SMS
  eventType          String    @db.VarChar(60) // NEW_TASK | APPROVED | REJECTED | RETURNED | OVERDUE | ...
  title              String    @db.VarChar(300)
  message            String    @db.Text
  status             String    @default("PENDING") @db.VarChar(20) // PENDING | SENT | FAILED
  scheduledAt        DateTime?
  sentAt             DateTime?
  readAt             DateTime?
  payloadJson        Json?
  createdAt          DateTime  @default(now())

  workflowInstance WorkflowInstance @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)

  // Indexes cho inbox count và unread badge
  @@index([recipientId, readAt])
  @@index([recipientId, channel])
  @@index([workflowInstanceId])
  @@index([scheduledAt, status])
  @@map("wf_notifications")
}

/**
 * M13 – Ghi nhận escalation khi bước bị treo quá hạn.
 * escalatedBy: "SYSTEM" (cron) hoặc userId (manual escalate).
 * Escalation không tự thay đổi dữ liệu nghiệp vụ gốc.
 */
model WorkflowEscalation {
  id                 String   @id @default(cuid())
  workflowInstanceId String
  stepInstanceId     String
  escalatedBy        String   @db.VarChar(36) // "SYSTEM" | userId
  escalatedTo        String?  @db.VarChar(36) // userId người nhận leo thang
  reason             String?  @db.VarChar(500)
  createdAt          DateTime @default(now())

  workflowInstance WorkflowInstance @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)

  @@index([workflowInstanceId])
  @@index([createdAt])
  @@map("wf_escalations")
}

/**
 * M13 – Audit log cấu trúc cho mọi thay đổi trạng thái workflow.
 * Ghi before/after, ai làm, lúc nào, từ IP/session nào.
 * Là nguồn sự thật cho compliance và forensics.
 */
model WorkflowAuditLog {
  id                 String   @id @default(cuid())
  workflowInstanceId String
  action             String   @db.VarChar(60)
  performedBy        String   @db.VarChar(36)
  performedAt        DateTime @default(now())
  fromStatus         String?  @db.VarChar(40)
  toStatus           String?  @db.VarChar(40)
  ipAddress          String?  @db.VarChar(45)
  sessionId          String?  @db.VarChar(100)
  comment            String?  @db.Text
  payloadJson        Json?

  workflowInstance WorkflowInstance @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)

  @@index([workflowInstanceId])
  @@index([performedBy, performedAt])
  @@map("wf_audit_logs")
}

// =============================================================================
// M13 – Enums
// =============================================================================

/// Trạng thái version của workflow template
enum WorkflowVersionStatus {
  DRAFT // đang soạn thảo, chưa dùng được
  PUBLISHED // đang active, workflow mới sẽ dùng version này
  ARCHIVED // đã khóa, không dùng nữa
}

/// Loại step trong định nghĩa quy trình
enum WorkflowStepType {
  START // bước bắt đầu, chỉ 1 trong mỗi template
  TASK // bước xử lý thông thường
  APPROVAL // bước yêu cầu phê duyệt
  SIGNATURE // bước yêu cầu ký số
  END // bước kết thúc
}

/// Trạng thái tổng của một workflow instance
enum WorkflowInstanceStatus {
  DRAFT // vừa khởi tạo, chưa submit
  PENDING // đã submit, đang chờ xử lý bước đầu
  IN_PROGRESS // đang trong quá trình duyệt
  APPROVED // đã duyệt hoàn toàn
  REJECTED // bị từ chối
  RETURNED // bị trả lại để bổ sung
  CANCELLED // bị hủy bởi người khởi tạo hoặc admin
  EXPIRED // quá hạn tổng workflow (nếu có SLA toàn quy trình)
  FAILED // lỗi hệ thống không phục hồi được
}

/// Trạng thái của từng step trong runtime
enum WorkflowStepStatus {
  WAITING // chờ step trước hoàn thành
  READY // sẵn sàng để xử lý, đã có assignee
  IN_PROGRESS // assignee đang xử lý
  APPROVED // step được duyệt
  REJECTED // step bị từ chối
  RETURNED // step bị trả lại
  SKIPPED // bỏ qua theo điều kiện (conditional branch)
  CANCELLED // bị hủy do workflow cancel
  EXPIRED // quá SLA của bước
}

/// Các action chuẩn người dùng hoặc hệ thống thực hiện tại một step
enum WorkflowActionCode {
  SUBMIT // người khởi tạo nộp hồ sơ
  APPROVE // phê duyệt bước
  REJECT // từ chối toàn bộ quy trình
  RETURN // trả lại bổ sung
  CANCEL // hủy quy trình
  SIGN // ký số điện tử
  COMMENT // cho ý kiến không thay đổi trạng thái
  REASSIGN // chuyển xử lý người khác
  ESCALATE // nâng cấp xử lý
  SYSTEM_TIMEOUT // hệ thống tự động đánh dấu quá hạn
}

/// Trạng thái chữ ký số tại một step
enum WorkflowSignatureStatus {
  PENDING // chờ ký
  SIGNED // đã ký thành công
  FAILED // ký thất bại (lỗi kỹ thuật)
  REVOKED // chữ ký bị thu hồi
  EXPIRED // chứng chỉ hết hạn
}

// ─────────────────────────────────────────────
// M07 – Enums
// ─────────────────────────────────────────────

/// M07 – Xu hướng điểm EIS giữa các kỳ
enum EisTrend {
  IMPROVING // đang cải thiện
  STABLE // ổn định
  DECLINING // đang giảm
}

/// M07 – Trạng thái xử lý cảnh báo quá tải/thiếu tải giảng viên
enum WorkloadAlertStatus {
  OPEN // chưa xử lý
  ACKNOWLEDGED // đã ghi nhận
  RESOLVED // đã giải quyết
}

/// M07 – Trạng thái học lực tích lũy của học viên (performance, khác với EduStudentStatus là lifecycle)
enum AcademicPerformanceStatus {
  NORMAL // học lực bình thường
  WARNING // cảnh báo học vụ (GPA thấp, nợ tín chỉ)
  PROBATION // bị xem xét đình chỉ học
  SUSPENDED // đình chỉ học (học thuật, khác TEMP_SUSPENDED lifecycle)
}

// ─────────────────────────────────────────────
// M07 – Models
// ─────────────────────────────────────────────

/// M07 – Snapshot điểm EIS giảng viên theo từng học kỳ.
/// Read-model: tính từ M10 (dạy/mentoring), M09 (nghiên cứu/sáng kiến), M03 (hoạt động).
/// KHÔNG cho chỉnh tay totalEIS nếu không có quyền FACULTY.EIS_MANAGE.
/// Unique: mỗi giảng viên chỉ có 1 bản EIS mỗi (academicYear, semesterCode).
model FacultyEISScore {
  id               String @id @default(cuid())
  facultyProfileId String

  academicYear String // VD: "2025-2026"
  semesterCode String // VD: "HK1"

  // Sáu chiều đánh giá – mỗi chiều thang 0–100, chuẩn hóa trước khi nhân trọng số
  teachingScore    Float @default(0) // T – Teaching quality (trọng số 0.25)
  researchScore    Float @default(0) // R – Research output (trọng số 0.25)
  mentoringScore   Float @default(0) // M – Mentoring (trọng số 0.20)
  serviceScore     Float @default(0) // S – Service/Đảng/đoàn (trọng số 0.15)
  innovationScore  Float @default(0) // I – Innovation/sáng kiến (trọng số 0.10)
  developmentScore Float @default(0) // D – Development/học thêm (trọng số 0.05)

  // Điểm tổng hợp: T×0.25 + R×0.25 + M×0.20 + S×0.15 + I×0.10 + D×0.05
  totalEIS Float     @default(0)
  trend    EisTrend? // so với kỳ liền trước

  // AI recommendations (JSON array, 1 phần tử/chiều nếu cần cải thiện)
  recommendations Json?
  // Snapshot raw inputs dùng để tính (audit trail – không cho sửa sau khi chốt)
  sourceDataJson  Json?

  calculatedAt DateTime @default(now())
  calculatedBy String? // userId hoặc 'system'
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  facultyProfile FacultyProfile @relation(fields: [facultyProfileId], references: [id], onDelete: Cascade)

  @@unique([facultyProfileId, academicYear, semesterCode])
  @@index([facultyProfileId])
  @@index([academicYear, semesterCode])
  @@index([totalEIS]) // ranking dashboard
  @@index([trend])
  @@map("faculty_eis_scores")
}

/// M07 – Snapshot tải giảng theo học kỳ.
/// Read-model: tính từ CourseSection/ClassSection trong M10.
/// Không nhập tay song song nếu đã có nguồn M10.
/// Rebuild định kỳ (cuối tuần hoặc cuối kỳ) để tránh runtime query nặng.
model FacultyWorkloadSnapshot {
  id               String @id @default(cuid())
  facultyProfileId String

  academicYear String // VD: "2025-2026"
  semesterCode String // VD: "HK1"

  totalClasses     Int   @default(0) // số lớp học phần đang dạy trong kỳ
  totalHoursWeekly Float @default(0) // giờ dạy/tuần thực tế (tính theo lịch M10)
  totalHoursTerm   Float @default(0) // tổng giờ dạy cả kỳ
  overloadHours    Float @default(0) // số giờ vượt định mức (nếu > weeklyHoursLimit)
  weeklyHoursLimit Float @default(16) // snapshot định mức tại thời điểm tính
  advisingCount    Int   @default(0) // số học viên cố vấn học tập
  thesisCount      Int   @default(0) // số khóa luận/luận văn đang hướng dẫn

  builtAt   DateTime @default(now()) // thời điểm rebuild snapshot
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  facultyProfile FacultyProfile         @relation(fields: [facultyProfileId], references: [id], onDelete: Cascade)
  alerts         FacultyWorkloadAlert[]

  @@unique([facultyProfileId, academicYear, semesterCode])
  @@index([facultyProfileId])
  @@index([academicYear, semesterCode])
  @@index([totalHoursWeekly]) // filter quá tải / thiếu tải
  @@index([overloadHours])
  @@map("faculty_workload_snapshots")
}

/// M07 – Cảnh báo tải giảng (quá tải hoặc thiếu tải).
/// Gắn với FacultyWorkloadSnapshot của kỳ tương ứng.
/// Dashboard khoa/bộ môn theo dõi và mark acknowledged/resolved.
model FacultyWorkloadAlert {
  id         String @id @default(cuid())
  snapshotId String

  // Loại cảnh báo: OVERLOAD | UNDERLOAD – có thể lookup M19 WORKLOAD_ALERT_TYPE sau
  alertType String
  status    WorkloadAlertStatus @default(OPEN)
  message   String?

  resolvedBy String? // userId người xử lý
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  snapshot FacultyWorkloadSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([status])
  @@index([alertType])
  @@map("faculty_workload_alerts")
}

/// M07 – Snapshot GPA học viên theo từng học kỳ.
/// Read-model: tính từ KetQuaHocTap (chỉ record có workflowStatus = APPROVED).
/// Source of truth điểm vẫn là KetQuaHocTap trong M10.
/// Unique: mỗi học viên chỉ có 1 snapshot mỗi (academicYear, semesterCode).
model StudentGpaHistory {
  id        String @id @default(cuid())
  hocVienId String

  academicYear String // VD: "2025-2026"
  semesterCode String // VD: "HK1"

  semesterGpa             Float @default(0) // GPA riêng kỳ này
  cumulativeGpa           Float @default(0) // GPA tích lũy đến hết kỳ này
  creditsEarned           Int   @default(0) // tín chỉ tích lũy được trong kỳ
  totalCreditsAccumulated Int   @default(0) // tổng tín chỉ tích lũy đến hết kỳ

  // Trạng thái học lực tại thời điểm snapshot – theo ngưỡng cảnh báo đã thống nhất
  academicStatus AcademicPerformanceStatus @default(NORMAL)

  builtAt   DateTime @default(now()) // thời điểm rebuild
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hocVien HocVien @relation(fields: [hocVienId], references: [id], onDelete: Cascade)

  @@unique([hocVienId, academicYear, semesterCode])
  @@index([hocVienId])
  @@index([academicYear, semesterCode])
  @@index([cumulativeGpa]) // ranking dashboard, top/bottom GPA
  @@index([academicStatus]) // filter cảnh báo học vụ
  @@map("student_gpa_histories")
}

// ─────────────────────────────────────────────────────────────────────────────
// CSDL-KHQL – Phase 1: Danh mục Khoa học (M01)
// Không đụng schema cũ. Path prefix /api/science/*
// ─────────────────────────────────────────────────────────────────────────────

/// Danh mục phân cấp dùng cho toàn bộ CSDL-KHQL.
/// type: FIELD | WORK_TYPE | PUBLISHER | FUND_SOURCE | LEVEL | RESEARCH_AREA
/// path: LTREE-style string, vd: "science.military.logistics"
model ScienceCatalog {
  id             String           @id @default(cuid())
  code           String           @unique
  name           String
  type           String
  parentId       String?
  parent         ScienceCatalog?  @relation("CatalogTree", fields: [parentId], references: [id])
  children       ScienceCatalog[] @relation("CatalogTree")
  level          Int              @default(1)
  path           String?
  description    String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  createdById    String
  createdBy      User             @relation("ScienceCatalogCreator", fields: [createdById], references: [id])
  fundedProjects NckhProject[]    @relation("ProjectFundSource")
  fundedBudgets  ResearchBudget[] @relation("BudgetFundSource")

  @@index([type, isActive])
  @@index([parentId])
  @@map("science_catalogs")
}

/// Sequence generator cho mã định danh CSDL-KHQL.
/// Format: HVHC-{YEAR}-{TYPE}-{SEQ:03d}
model ScienceIdSequence {
  id         String @id @default(cuid())
  entityType String
  year       Int
  lastSeq    Int    @default(0)

  @@unique([entityType, year])
  @@map("science_id_sequences")
}

// ─────────────────────────────────────────────────────────────────────────────
// CSDL-KHQL – Phase 3: Workflow log + ScientificWork (M04)
// Additive only – không drop/alter gì ở NckhProject hay NckhPublication
// ─────────────────────────────────────────────────────────────────────────────

/// Audit trail mỗi lần chuyển trạng thái / phase đề tài nghiên cứu.
model NckhProjectWorkflowLog {
  id         String      @id @default(cuid())
  projectId  String
  project    NckhProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromStatus String
  toStatus   String
  fromPhase  String?
  toPhase    String?
  actionById String
  actionBy   User        @relation("WorkflowLogActor", fields: [actionById], references: [id])
  comment    String?
  actedAt    DateTime    @default(now())

  @@index([projectId])
  @@index([actedAt])
  @@map("nckh_project_workflow_logs")
}

/// Công trình khoa học: sách, giáo trình, tài liệu tham khảo (M04).
/// Khác NckhPublication (bài báo/hội thảo) – đây là sản phẩm dạng xuất bản phẩm.
model ScientificWork {
  id                String                       @id @default(cuid())
  code              String                       @unique // HVHC-{YEAR}-WORK-{SEQ:03d}
  type              String // TEXTBOOK|BOOK|MONOGRAPH|REFERENCE|CURRICULUM
  title             String
  subtitle          String?
  isbn              String?
  issn              String?
  doi               String?                      @unique
  publisherId       String? // FK → ScienceCatalog (type=PUBLISHER)
  journalName       String?
  year              Int
  edition           Int                          @default(1)
  sensitivity       String                       @default("NORMAL") // NORMAL|CONFIDENTIAL|SECRET
  abstractEmbedding Unsupported("vector(1536)")? // pgvector Phase 5 – requires postgresql-16-pgvector
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt
  isDeleted         Boolean                      @default(false)
  authors           ScientificWorkAuthor[]
  libraryItems      LibraryItem[]

  @@index([type, year])
  @@index([isDeleted])
  @@index([publisherId])
  @@index([sensitivity, isDeleted]) // download permission filter
  @@map("scientific_works")
}

model ScientificWorkAuthor {
  id          String         @id @default(cuid())
  workId      String
  work        ScientificWork @relation(fields: [workId], references: [id], onDelete: Cascade)
  scientistId String? // Link → NckhScientistProfile.id nếu nội bộ
  authorName  String
  role        String // LEAD|CO_AUTHOR|EDITOR|REVIEWER
  orderNum    Int
  affiliation String?

  @@unique([workId, orderNum])
  @@index([workId])
  @@index([scientistId])
  @@map("scientific_work_authors")
}

// ─────────────────────────────────────────────────────────────────────────────
// CSDL-KHQL – Phase 4: Thư viện Số (Digital Library)
// ─────────────────────────────────────────────────────────────────────────────

/// Tài liệu số trong thư viện KH.
/// filePath = MinIO object key: library/{sensitivity}/{uuid}.{ext}
model LibraryItem {
  id             String                       @id @default(cuid())
  workId         String? // FK → ScientificWork (tuỳ chọn)
  work           ScientificWork?              @relation(fields: [workId], references: [id])
  title          String
  filePath       String // MinIO object key
  fileSize       BigInt
  mimeType       String
  checksumSha256 String
  sensitivity    String                       @default("NORMAL") // NORMAL|CONFIDENTIAL|SECRET
  accessCount    Int                          @default(0)
  downloadCount  Int                          @default(0)
  textEmbedding  Unsupported("vector(1536)")? // pgvector Phase 5 – requires postgresql-16-pgvector
  isIndexed      Boolean                      @default(false)
  indexedAt      DateTime?
  createdAt      DateTime                     @default(now())
  isDeleted      Boolean                      @default(false)
  createdById    String
  createdBy      User                         @relation("LibraryItemCreator", fields: [createdById], references: [id])
  accessLogs     LibraryAccessLog[]

  @@index([sensitivity, isDeleted])
  @@index([workId])
  @@index([createdById])
  @@index([isIndexed, isDeleted]) // worker picks up pending index jobs
  @@map("library_items")
}

/// Audit log mỗi lần VIEW hoặc DOWNLOAD tài liệu thư viện.
model LibraryAccessLog {
  id         String      @id @default(cuid())
  itemId     String
  item       LibraryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  action     String // VIEW|DOWNLOAD
  ipAddress  String?
  accessedAt DateTime    @default(now())

  @@index([itemId, accessedAt])
  @@index([userId])
  @@map("library_access_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// CSDL-KHQL – Phase 5: Kinh phí + Hội đồng KH
// Additive – NckhProject.budgetApproved/budgetRequested GIỮ NGUYÊN
// ─────────────────────────────────────────────────────────────────────────────

/// Chi tiết kinh phí đề tài (1-1 với NckhProject).
/// Không thay thế NckhProject.budgetApproved – bổ sung thêm tracking chi tiết.
model ResearchBudget {
  id            String           @id @default(cuid())
  projectId     String           @unique
  project       NckhProject      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fundSourceId  String
  fundSource    ScienceCatalog   @relation("BudgetFundSource", fields: [fundSourceId], references: [id])
  totalApproved BigInt
  totalSpent    BigInt           @default(0)
  year          Int
  status        String           @default("DRAFT") // DRAFT|APPROVED|FINALIZED
  approvedById  String?
  approvedBy    User?            @relation("BudgetApprover", fields: [approvedById], references: [id])
  approvedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  lineItems     BudgetLineItem[]

  @@index([fundSourceId])
  @@index([year, status])
  @@map("research_budgets")
}

model BudgetLineItem {
  id            String         @id @default(cuid())
  budgetId      String
  budget        ResearchBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  category      String // PERSONNEL|EQUIPMENT|TRAVEL|OVERHEAD|OTHER
  description   String
  plannedAmount BigInt
  spentAmount   BigInt         @default(0)
  period        String? // Q1-2026|Q2-2026|...

  @@index([budgetId])
  @@map("budget_line_items")
}

/// Hội đồng KH chính thức – bổ sung cho NckhReview, không thay thế.
model ScientificCouncil {
  id                 String                    @id @default(cuid())
  projectId          String
  project            NckhProject               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type               String // REVIEW|ACCEPTANCE|FINAL
  chairmanId         String
  chairman           User                      @relation("CouncilChairman", fields: [chairmanId], references: [id])
  secretaryId        String
  secretary          User                      @relation("CouncilSecretary", fields: [secretaryId], references: [id])
  meetingDate        DateTime?
  result             String? // PASS|FAIL|REVISE
  overallScore       Float?
  conclusionText     String?
  minutesFilePath    String? // MinIO path – Sprint 05: will be populated by M18 render
  // Sprint 02: tracks M18 ExportJob.id once council minutes rendering is wired (Sprint 05)
  minutesExportJobId String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  members            ScientificCouncilMember[]
  reviews            ScientificCouncilReview[]
  // Phase 6 additive
  meetings           NckhCouncilMeeting[]       @relation("NckhCouncilMeetings")
  acceptances        NckhAcceptance[]           @relation("NckhAcceptanceCouncil")
  midtermReviews     NckhMidtermReview[]        @relation("NckhMidtermCouncil")

  @@index([projectId])
  @@index([type])
  @@index([result]) // filter councils by PASS/FAIL/REVISE
  @@map("scientific_councils")
}

model ScientificCouncilMember {
  id          String                @id @default(cuid())
  councilId   String
  council     ScientificCouncil     @relation(fields: [councilId], references: [id], onDelete: Cascade)
  userId      String
  user        User                  @relation(fields: [userId], references: [id])
  // Additive: FK tường minh → NckhScientistProfile (nullable – external expert có thể chưa có profile)
  scientistId String?
  scientist   NckhScientistProfile? @relation("CouncilMemberScientist", fields: [scientistId], references: [id])
  role        String // CHAIRMAN|SECRETARY|REVIEWER|EXPERT
  /// Phiếu bầu kín – chỉ CHAIRMAN + ADMIN được đọc (enforced tại service layer)
  vote        String? // PASS|FAIL|REVISE

  @@unique([councilId, userId])
  @@index([userId])
  @@index([scientistId])
  @@map("scientific_council_members")
}

/// Điểm chấm chi tiết của từng thành viên phản biện theo tiêu chí.
model ScientificCouncilReview {
  id        String            @id @default(cuid())
  councilId String
  council   ScientificCouncil @relation(fields: [councilId], references: [id], onDelete: Cascade)
  memberId  String // FK → ScientificCouncilMember.id
  criteria  String // SCIENTIFIC_VALUE|FEASIBILITY|BUDGET|TEAM|OUTCOME
  score     Float // 0–10
  comment   String?
  createdAt DateTime          @default(now())

  @@index([councilId])
  @@index([memberId])
  @@map("scientific_council_reviews")
}

// ─────────────────────────────────────────────────────────────────────────────
// M11 – Dashboard & Trực quan hóa
// ─────────────────────────────────────────────────────────────────────────────

enum DashboardRoleKey {
  EXECUTIVE   // Ban Giám đốc Học viện
  DEPARTMENT  // Trưởng phòng / khoa
  EDUCATION   // Phòng Đào tạo
  PARTY       // Phòng Chính trị
  FACULTY     // Giảng viên
  STUDENT     // Học viên / Sinh viên
}

enum DashboardAccessAction {
  VIEW
  EXPORT
  REFRESH
  LAYOUT_SAVE
  LAYOUT_RESET
  ALERT_ACK
}

/// Layout mặc định theo role – do admin cấu hình, là template gốc cho toàn role.
model DashboardRoleTemplate {
  id          String           @id @default(cuid())
  /// Mỗi role chỉ có một template active tại một thời điểm
  roleKey     DashboardRoleKey @unique
  /// JSON array of { widgetId, x, y, w, h }
  layoutJson  Json
  /// Widget keys được phép dùng trong role này
  widgetKeys  String[]
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  userLayouts DashboardUserLayout[]

  @@map("dashboard_role_templates")
}

/// Layout cá nhân hóa của từng user – tùy chỉnh trong phạm vi role template cho phép.
model DashboardUserLayout {
  id           String                @id @default(cuid())
  userId       String
  user         User                  @relation("UserDashboardLayouts", fields: [userId], references: [id], onDelete: Cascade)
  dashboardKey DashboardRoleKey
  /// JSON array of { widgetId, x, y, w, h } – user's overrides
  layoutJson   Json
  /// Trỏ về template gốc đã dùng để tạo layout này
  templateId   String?
  template     DashboardRoleTemplate? @relation(fields: [templateId], references: [id])
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([userId, dashboardKey])
  @@index([userId])
  @@map("dashboard_user_layouts")
}

/// Cache aggregate data cho từng widget, có scope key để tránh rò rỉ dữ liệu giữa role/đơn vị.
/// Không phải source of truth – chỉ là read-model tạm thời.
model DashboardWidgetDataCache {
  id         String   @id @default(cuid())
  widgetKey  String
  /// Compound scope key: "role:{roleKey}:scope:{scope}:unit:{unitId}" hoặc "user:{userId}"
  scopeKey   String
  dataJson   Json
  cachedAt   DateTime @default(now())
  expiresAt  DateTime
  ttlSeconds Int

  @@unique([widgetKey, scopeKey])
  @@index([widgetKey])
  @@index([expiresAt]) // dùng cho cleanup job
  @@map("dashboard_widget_data_cache")
}

/// Audit log truy cập dashboard – ghi VIEW, EXPORT, REFRESH, LAYOUT_SAVE, LAYOUT_RESET, ALERT_ACK.
model DashboardAccessLog {
  id           String                @id @default(cuid())
  userId       String
  user         User                  @relation("UserDashboardAccessLogs", fields: [userId], references: [id])
  dashboardKey String
  action       DashboardAccessAction
  /// Metadata tuỳ theo action: { widgetKey, exportFormat, ... }
  meta         Json?
  createdAt    DateTime              @default(now())

  @@index([userId])
  @@index([dashboardKey])
  @@index([action])
  @@index([createdAt])
  @@map("dashboard_access_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// CSDL-KHQL – Phase 6: Enums mới cho Lifecycle NCKH
// ─────────────────────────────────────────────────────────────────────────────

enum NckhProposalStatus {
  DRAFT
  SUBMITTED
  REVIEWING
  UNIT_APPROVED
  DEPT_APPROVED
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

enum NckhReportType {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum NckhReportStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  APPROVED
}

enum NckhMidtermRecommendation {
  CONTINUE
  ADJUST
  TERMINATE
}

enum NckhExtensionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NckhClosureType {
  COMPLETED
  TERMINATED
  TRANSFERRED
}

enum NckhImpactLevel {
  HIGH
  MEDIUM
  LOW
}

enum NckhAcceptanceType {
  PRELIMINARY
  FINAL
}

enum NckhAcceptanceResult {
  PASS
  FAIL
  CONDITIONAL
}

enum NckhVoteResult {
  APPROVE
  REJECT
  ABSTAIN
}

enum NckhPoStatus {
  DRAFT
  SUBMITTED
  APPROVED
  RECEIVED
  CANCELLED
}

enum NckhInvoiceStatus {
  PENDING
  APPROVED
  PAID
  DISPUTED
  CANCELLED
}

enum NckhExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REIMBURSED
}

enum NckhExpenseCategory {
  PERSONNEL
  EQUIPMENT
  TRAVEL
  OVERHEAD
  PRINTING
  OTHER
}

enum NckhGrantStatus {
  PENDING
  ACTIVE
  COMPLETED
  TERMINATED
}

enum NckhCollaborationType {
  INTERNAL
  EXTERNAL
  INTERNATIONAL
}

// ─────────────────────────────────────────────────────────────────────────────
// CSDL-KHQL – Phase 6: Lifecycle NCKH (Proposal → Closure)
// Additive – không sửa NckhProject, ScientificCouncil
// ─────────────────────────────────────────────────────────────────────────────

/// Đề xuất NCKH chính thức — có workflow phê duyệt trước khi thành NckhProject.
model NckhProposal {
  id              String             @id @default(cuid())
  title           String
  titleEn         String?
  abstract        String?
  keywords        String[]
  researchType    NckhType
  category        NckhCategory
  field           NckhField
  budgetRequested Float
  durationMonths  Int
  piId            String
  pi              User               @relation("NckhProposalPI", fields: [piId], references: [id])
  unitId          String?
  unit            Unit?              @relation("NckhProposalUnit", fields: [unitId], references: [id])
  status          NckhProposalStatus @default(DRAFT)
  submittedAt     DateTime?
  reviewDeadline  DateTime?

  // Multi-level approval
  currentLevel    String             @default("UNIT") // "UNIT" | "DEPT" | "ACADEMY"
  unitApprovedAt  DateTime?
  unitApprovedById String?
  unitApprovedBy  User?              @relation("NckhProposalUnitApprover", fields: [unitApprovedById], references: [id])
  deptApprovedAt  DateTime?
  deptApprovedById String?
  deptApprovedBy  User?              @relation("NckhProposalDeptApprover", fields: [deptApprovedById], references: [id])

  approvedAt      DateTime?
  approvedById    String?
  approvedBy      User?              @relation("NckhProposalApprover", fields: [approvedById], references: [id])
  rejectedAt      DateTime?
  rejectReason    String?

  // REVISION flow
  revisionNote    String?
  revisionCount   Int                @default(0)
  revisedAt       DateTime?

  projectId       String?            @unique // set khi approve → NckhProject được tạo
  project         NckhProject?       @relation(fields: [projectId], references: [id])
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  reviews         NckhProposalReview[]

  @@index([piId])
  @@index([unitId])
  @@index([status])
  @@index([currentLevel])
  @@index([submittedAt])
  @@map("nckh_proposals")
}

/// Chấm điểm đề xuất NCKH bởi hội đồng thẩm định.
model NckhProposalReview {
  id             String         @id @default(cuid())
  proposalId     String
  proposal       NckhProposal   @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  reviewerId     String
  reviewer       User           @relation("NckhProposalReviewer", fields: [reviewerId], references: [id])
  score          Float?
  comment        String?
  recommendation String         // APPROVE|REJECT|REVISE
  reviewedAt     DateTime       @default(now())
  createdAt      DateTime       @default(now())

  @@unique([proposalId, reviewerId])
  @@index([proposalId])
  @@index([reviewerId])
  @@map("nckh_proposal_reviews")
}

/// Báo cáo tiến độ định kỳ của đề tài NCKH.
model NckhProgressReport {
  id                String           @id @default(cuid())
  projectId         String
  project           NckhProject      @relation("NckhProjectReports", fields: [projectId], references: [id], onDelete: Cascade)
  reportPeriod      String           // VD: "Q1-2025", "T01/2025"
  reportType        NckhReportType
  status            NckhReportStatus @default(DRAFT)
  content           String?
  completionPercent Float            @default(0)
  issues            String?
  nextSteps         String?
  attachmentUrl     String?
  submittedById     String
  submittedBy       User             @relation("NckhReportSubmitter", fields: [submittedById], references: [id])
  submittedAt       DateTime?
  reviewedAt        DateTime?
  reviewNote        String?
  reviewedById      String?
  reviewedBy        User?            @relation("NckhReportReviewer", fields: [reviewedById], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([reportType])
  @@map("nckh_progress_reports")
}

/// Đánh giá giữa kỳ chính thức — có form điểm số từng tiêu chí.
model NckhMidtermReview {
  id                  String                    @id @default(cuid())
  projectId           String                    @unique
  project             NckhProject               @relation("NckhMidtermReview", fields: [projectId], references: [id], onDelete: Cascade)
  councilId           String?
  council             ScientificCouncil?        @relation("NckhMidtermCouncil", fields: [councilId], references: [id])
  reviewDate          DateTime
  overallScore        Float?
  scientificScore     Float?
  progressScore       Float?
  budgetScore         Float?
  recommendation      NckhMidtermRecommendation
  adjustmentRequired  Boolean                   @default(false)
  adjustmentNote      String?
  conclusionText      String?
  approvedById        String?
  approvedBy          User?                     @relation("NckhMidtermApprover", fields: [approvedById], references: [id])
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@index([projectId])
  @@index([councilId])
  @@map("nckh_midterm_reviews")
}

/// Yêu cầu gia hạn đề tài — có workflow phê duyệt.
model NckhExtension {
  id               String              @id @default(cuid())
  projectId        String
  project          NckhProject         @relation("NckhProjectExtensions", fields: [projectId], references: [id], onDelete: Cascade)
  originalEndDate  DateTime
  requestedEndDate DateTime
  extensionMonths  Int
  reason           String
  status           NckhExtensionStatus @default(PENDING)
  requestedById    String
  requestedBy      User                @relation("NckhExtensionRequester", fields: [requestedById], references: [id])
  approvedById     String?
  approvedBy       User?               @relation("NckhExtensionApprover", fields: [approvedById], references: [id])
  approvedAt       DateTime?
  rejectReason     String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([projectId])
  @@index([status])
  @@map("nckh_extensions")
}

/// Đóng đề tài chính thức (hoàn thành, dừng, hoặc chuyển giao).
model NckhClosure {
  id              String          @id @default(cuid())
  projectId       String          @unique
  project         NckhProject     @relation("NckhClosure", fields: [projectId], references: [id], onDelete: Cascade)
  closureType     NckhClosureType
  closureDate     DateTime
  finalScore      Float?
  finalGrade      String?
  archiveLocation String?
  notes           String?
  closedById      String
  closedBy        User            @relation("NckhClosureBy", fields: [closedById], references: [id])
  createdAt       DateTime        @default(now())

  @@index([projectId])
  @@index([closureType])
  @@map("nckh_closures")
}

/// Bài học kinh nghiệm từ đề tài — knowledge base tích lũy theo thời gian.
model NckhLessonLearned {
  id             String          @id @default(cuid())
  projectId      String
  project        NckhProject     @relation("NckhLessonsLearned", fields: [projectId], references: [id], onDelete: Cascade)
  category       String          // MANAGEMENT|TECHNICAL|FINANCIAL|COLLABORATION|OTHER
  title          String
  description    String
  impact         NckhImpactLevel
  recommendation String?
  addedById      String
  addedBy        User            @relation("NckhLessonAuthor", fields: [addedById], references: [id])
  createdAt      DateTime        @default(now())

  @@index([projectId])
  @@index([impact])
  @@map("nckh_lessons_learned")
}

/// Nghiệm thu chính thức đề tài — chi tiết hơn NckhReview.
model NckhAcceptance {
  id               String               @id @default(cuid())
  projectId        String               @unique
  project          NckhProject          @relation("NckhAcceptance", fields: [projectId], references: [id], onDelete: Cascade)
  councilId        String?
  council          ScientificCouncil?   @relation("NckhAcceptanceCouncil", fields: [councilId], references: [id])
  acceptanceDate   DateTime
  acceptanceType   NckhAcceptanceType
  finalScore       Float?
  grade            String?
  result           NckhAcceptanceResult
  conditions       String?
  signedMinutesUrl String?
  acceptedById     String
  acceptedBy       User                 @relation("NckhAcceptanceBy", fields: [acceptedById], references: [id])
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  scores           NckhAcceptanceScore[]

  @@index([projectId])
  @@index([result])
  @@map("nckh_acceptances")
}

/// Điểm chấm chi tiết của từng thành viên hội đồng nghiệm thu.
model NckhAcceptanceScore {
  id           String         @id @default(cuid())
  acceptanceId String
  acceptance   NckhAcceptance @relation(fields: [acceptanceId], references: [id], onDelete: Cascade)
  memberId     String         // FK → ScientificCouncilMember.id
  criteria     String         // SCIENTIFIC_VALUE|FEASIBILITY|OUTCOMES|BUDGET|TEAM
  score        Float
  comment      String?
  createdAt    DateTime       @default(now())

  @@index([acceptanceId])
  @@map("nckh_acceptance_scores")
}

/// Phiên họp hội đồng KH — 1 hội đồng có thể họp nhiều phiên.
model NckhCouncilMeeting {
  id              String            @id @default(cuid())
  councilId       String
  council         ScientificCouncil @relation("NckhCouncilMeetings", fields: [councilId], references: [id], onDelete: Cascade)
  meetingDate     DateTime
  location        String?
  agenda          String?
  minutesContent  String?
  minutesUrl      String?
  attendanceCount Int               @default(0)
  createdById     String
  createdBy       User              @relation("NckhMeetingCreator", fields: [createdById], references: [id])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  votes           NckhMeetingVote[]

  @@index([councilId])
  @@index([meetingDate])
  @@map("nckh_council_meetings")
}

/// Phiếu bầu chi tiết theo phiên họp — chỉ CHAIRMAN + ADMIN được tổng hợp.
model NckhMeetingVote {
  id        String             @id @default(cuid())
  meetingId String
  meeting   NckhCouncilMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  memberId  String             // FK → ScientificCouncilMember.id
  voteType  String             // APPROVAL|SCORE|RECOMMENDATION
  vote      NckhVoteResult
  score     Float?
  comment   String?
  votedAt   DateTime           @default(now())

  @@unique([meetingId, memberId, voteType])
  @@index([meetingId])
  @@map("nckh_meeting_votes")
}

// ─────────────────────────────────────────────────────────────────────────────
// CSDL-KHQL – Phase 7: Tài chính Granular (PO, Invoice, Expense, Grant)
// Bổ sung cho ResearchBudget hiện có — không thay thế.
// ─────────────────────────────────────────────────────────────────────────────

/// Đề nghị mua sắm theo đề tài NCKH.
model NckhPurchaseOrder {
  id           String                  @id @default(cuid())
  projectId    String
  project      NckhProject             @relation("NckhProjectPOs", fields: [projectId], references: [id], onDelete: Cascade)
  poNumber     String                  @unique // auto: PO-{YEAR}-{SEQ:04d}
  vendor       String
  orderDate    DateTime                @default(now())
  totalAmount  BigInt
  currency     String                  @default("VND")
  status       NckhPoStatus            @default(DRAFT)
  approvedById String?
  approvedBy   User?                   @relation("NckhPOApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  notes        String?
  createdById  String
  createdBy    User                    @relation("NckhPOCreator", fields: [createdById], references: [id])
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  items        NckhPurchaseOrderItem[]
  invoices     NckhInvoice[]

  @@index([projectId])
  @@index([status])
  @@index([orderDate])
  @@map("nckh_purchase_orders")
}

model NckhPurchaseOrderItem {
  id        String              @id @default(cuid())
  poId      String
  po        NckhPurchaseOrder   @relation(fields: [poId], references: [id], onDelete: Cascade)
  itemName  String
  quantity  Float
  unitPrice BigInt
  amount    BigInt
  category  NckhExpenseCategory
  unit      String?             // đơn vị tính: cái, bộ, tháng...
  notes     String?

  @@index([poId])
  @@map("nckh_purchase_order_items")
}

/// Hóa đơn gắn với đề tài (có thể liên kết với PO hoặc độc lập).
model NckhInvoice {
  id            String            @id @default(cuid())
  projectId     String
  project       NckhProject       @relation("NckhProjectInvoices", fields: [projectId], references: [id], onDelete: Cascade)
  poId          String?
  po            NckhPurchaseOrder? @relation(fields: [poId], references: [id])
  invoiceNumber String            @unique
  vendor        String
  invoiceDate   DateTime
  dueDate       DateTime?
  totalAmount   BigInt
  currency      String            @default("VND")
  status        NckhInvoiceStatus @default(PENDING)
  paidAt        DateTime?
  paidById      String?
  paidBy        User?             @relation("NckhInvoicePayer", fields: [paidById], references: [id])
  notes         String?
  createdById   String
  createdBy     User              @relation("NckhInvoiceCreator", fields: [createdById], references: [id])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  items         NckhInvoiceItem[]

  @@index([projectId])
  @@index([poId])
  @@index([status])
  @@map("nckh_invoices")
}

model NckhInvoiceItem {
  id          String              @id @default(cuid())
  invoiceId   String
  invoice     NckhInvoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float
  unitPrice   BigInt
  amount      BigInt
  category    NckhExpenseCategory

  @@index([invoiceId])
  @@map("nckh_invoice_items")
}

/// Chi tiêu thực tế của đề tài — có workflow duyệt/hoàn tiền.
model NckhExpense {
  id            String              @id @default(cuid())
  projectId     String
  project       NckhProject         @relation("NckhProjectExpenses", fields: [projectId], references: [id], onDelete: Cascade)
  expenseDate   DateTime
  category      NckhExpenseCategory
  amount        BigInt
  description   String
  receiptUrl    String?
  status        NckhExpenseStatus   @default(DRAFT)
  submittedById String
  submittedBy   User                @relation("NckhExpenseSubmitter", fields: [submittedById], references: [id])
  approvedById  String?
  approvedBy    User?               @relation("NckhExpenseApprover", fields: [approvedById], references: [id])
  approvedAt    DateTime?
  rejectReason  String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([category])
  @@index([expenseDate])
  @@map("nckh_expenses")
}

/// Tài trợ / grant ngoài ngân sách nhà nước.
model NckhGrant {
  id             String                  @id @default(cuid())
  projectId      String
  project        NckhProject             @relation("NckhProjectGrants", fields: [projectId], references: [id], onDelete: Cascade)
  grantNumber    String                  @unique
  grantor        String                  // tên tổ chức tài trợ
  grantorType    String                  @default("DOMESTIC") // DOMESTIC|INTERNATIONAL|INDUSTRY
  amount         BigInt
  currency       String                  @default("VND")
  startDate      DateTime
  endDate        DateTime
  conditions     String?
  status         NckhGrantStatus         @default(ACTIVE)
  reportDeadline DateTime?
  createdById    String
  createdBy      User                    @relation("NckhGrantCreator", fields: [createdById], references: [id])
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  disbursements  NckhGrantDisbursement[]

  @@index([projectId])
  @@index([status])
  @@map("nckh_grants")
}

model NckhGrantDisbursement {
  id               String    @id @default(cuid())
  grantId          String
  grant            NckhGrant @relation(fields: [grantId], references: [id], onDelete: Cascade)
  disbursementDate DateTime
  amount           BigInt
  description      String?
  receiptUrl       String?
  createdAt        DateTime  @default(now())

  @@index([grantId])
  @@map("nckh_grant_disbursements")
}

// ─────────────────────────────────────────────────────────────────────────────
// CSDL-KHQL – Phase 8: Chat Nhóm Dự án & Hợp tác Nghiên cứu
// ─────────────────────────────────────────────────────────────────────────────

/// Phòng chat gắn 1-1 với NckhProject — tạo tự động khi project được tạo.
model NckhChatRoom {
  id           String                @id @default(cuid())
  projectId    String                @unique
  project      NckhProject           @relation("NckhProjectChat", fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  createdAt    DateTime              @default(now())
  participants NckhChatParticipant[]
  messages     NckhChatMessage[]

  @@map("nckh_chat_rooms")
}

model NckhChatParticipant {
  id         String       @id @default(cuid())
  roomId     String
  room       NckhChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId     String
  user       User         @relation("NckhChatParticipant", fields: [userId], references: [id])
  joinedAt   DateTime     @default(now())
  lastReadAt DateTime?

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
  @@map("nckh_chat_participants")
}

model NckhChatMessage {
  id        String       @id @default(cuid())
  roomId    String
  room      NckhChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User         @relation("NckhChatSender", fields: [senderId], references: [id])
  content   String
  fileUrl   String?
  isEdited  Boolean      @default(false)
  isDeleted Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([roomId, createdAt])
  @@index([senderId])
  @@map("nckh_chat_messages")
}

/// Hợp tác nghiên cứu liên đơn vị hoặc quốc tế.
model NckhCollaboration {
  id              String                       @id @default(cuid())
  projectId       String
  project         NckhProject                  @relation("NckhProjectCollabs", fields: [projectId], references: [id], onDelete: Cascade)
  type            NckhCollaborationType
  partnerName     String
  partnerCountry  String?
  partnerUnit     String?
  agreementNumber String?
  startDate       DateTime
  endDate         DateTime?
  status          String                       @default("ACTIVE") // ACTIVE|COMPLETED|TERMINATED
  notes           String?
  createdById     String
  createdBy       User                         @relation("NckhCollabCreator", fields: [createdById], references: [id])
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  participants    NckhCollaborationParticipant[]
  documents       NckhCollaborationDocument[]

  @@index([projectId])
  @@index([type])
  @@map("nckh_collaborations")
}

model NckhCollaborationParticipant {
  id              String            @id @default(cuid())
  collaborationId String
  collaboration   NckhCollaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?             @relation("NckhCollabParticipant", fields: [userId], references: [id])
  name            String            // tên đối tác ngoài (khi không có user trong hệ thống)
  institution     String?
  role            String?
  createdAt       DateTime          @default(now())

  @@index([collaborationId])
  @@map("nckh_collaboration_participants")
}

model NckhCollaborationDocument {
  id              String            @id @default(cuid())
  collaborationId String
  collaboration   NckhCollaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)
  title           String
  fileUrl         String
  docType         String            // AGREEMENT|REPORT|CORRESPONDENCE|OTHER
  uploadedById    String
  uploadedBy      User              @relation("NckhCollabDocUploader", fields: [uploadedById], references: [id])
  createdAt       DateTime          @default(now())

  @@index([collaborationId])
  @@map("nckh_collaboration_documents")
}

// ─────────────────────────────────────────────────────────────────────────────
// CSDL-KHQL – Phase 6: File Minh Chứng Đính Kèm (Science Attachments)
// Polymorphic attachment model — một bảng dùng cho toàn bộ module khoa học.
// Reuse MinIO pipeline từ library.service.ts, bucket: hvhc-science-attachments
// ─────────────────────────────────────────────────────────────────────────────

enum ScienceAttachmentCategory {
  // Đề xuất / Proposal
  THUYET_MINH_DE_TAI      // Thuyết minh đề tài (bắt buộc khi nộp)
  CV_CHU_NHIEM            // CV chủ nhiệm đề tài
  THU_GIOI_THIEU          // Thư giới thiệu / hỗ trợ

  // Đề tài / Project
  HOP_DONG_NGHIEN_CUU     // Hợp đồng nghiên cứu
  QUYET_DINH_PHE_DUYET    // Quyết định phê duyệt

  // Tiến độ / Progress
  BAO_CAO_TIEN_DO         // Báo cáo tiến độ định kỳ
  MINH_CHUNG_MILESTONE    // Minh chứng hoàn thành milestone

  // Nghiệm thu / Kết thúc
  BAO_CAO_TONG_KET        // Báo cáo tổng kết
  BIEN_BAN_NGHIEM_THU     // Biên bản nghiệm thu

  // Công bố / Sáng kiến
  BAN_THAO_CONG_BO        // Bản thảo bài báo / công bố
  GIAY_CHAP_NHAN_XUAT_BAN // Giấy chấp nhận xuất bản
  BANG_CHUNG_SANG_KIEN    // Bằng chứng sáng kiến (pubType=SANG_KIEN)
  BANG_DOC_QUYEN          // Bằng độc quyền sáng chế (PATENT)

  // Tài chính
  HOA_DON_CHI_TIEU        // Hóa đơn / chứng từ chi tiêu
  BIEN_LAI_THU_CHI        // Biên lai thu chi (grant disbursement)

  // Hội đồng
  BIEN_BAN_HOI_DONG       // Biên bản họp hội đồng
  PHIEU_DANH_GIA          // Phiếu đánh giá thành viên hội đồng

  // Chung
  TAI_LIEU_KHAC           // Tài liệu khác
}

/// File minh chứng đính kèm cho bất kỳ entity khoa học nào.
/// entityType: "PROPOSAL"|"PROJECT"|"PUBLICATION"|"MILESTONE"|"PROGRESS_REPORT"
///           | "EXPENSE"|"GRANT_DISBURSEMENT"|"ACCEPTANCE"|"COUNCIL_MEETING"
///           | "CLOSURE"|"MIDTERM_REVIEW"
/// filePath = MinIO object key: science-attachments/{entityType}/{uuid}.{ext}
model ScienceAttachment {
  id             String                    @id @default(cuid())
  entityType     String                    // tên loại entity (xem enum trên)
  entityId       String                    // id của entity tương ứng
  docCategory    ScienceAttachmentCategory
  title          String                    // tên tài liệu hiển thị
  description    String?
  filePath       String                    // MinIO object key
  fileSize       BigInt
  mimeType       String
  checksumSha256 String
  sensitivity    String                    @default("NORMAL") // NORMAL|CONFIDENTIAL|SECRET
  version        Int                       @default(1)
  isLatest       Boolean                   @default(true)
  uploadedById   String
  uploadedBy     User                      @relation("ScienceAttachmentUploader", fields: [uploadedById], references: [id])
  isDeleted      Boolean                   @default(false)
  deletedById    String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@index([entityType, entityId])
  @@index([uploadedById])
  @@index([createdAt])
  @@map("science_attachments")
}

// =============================================================================
// MODULE M12 – DATA MANAGEMENT & INFRASTRUCTURE
// =============================================================================

// --- Pipeline Definition (tái sử dụng: DataPipeline hiện tại = run record) ---
// Định nghĩa pipeline tách khỏi run. Mỗi definition có thể chạy nhiều lần.
model PipelineDefinition {
  id              String             @id @default(cuid())
  name            String
  description     String?
  pipelineType    PipelineDefType    // ETL_PG_TO_CLICKHOUSE | DATA_QUALITY | BACKUP | AI_REFRESH | CUSTOM
  sourceDataset   String             // tên table/collection nguồn
  targetDataset   String?            // tên table/dataset đích
  scheduleCron    String?            // cron expression, null = chỉ trigger manual
  isActive        Boolean            @default(true)
  steps           Json               // mảng bước thực thi: [{name, type, config}]
  parameters      Json?              // tham số cấu hình thêm
  lastRunAt       DateTime?
  lastRunStatus   PipelineRunStatus?
  createdById     String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  runs            PipelineRun[]

  @@index([pipelineType])
  @@index([isActive])
  @@index([lastRunAt])
  @@map("pipeline_definitions")
}

// Run của một pipeline definition. Ghi nhận kết quả từng lần chạy.
model PipelineRun {
  id               String            @id @default(cuid())
  definitionId     String
  triggeredBy      PipelineTrigger   // MANUAL | SCHEDULED | API | EVENT
  triggeredById    String?           // user id nếu manual
  status           PipelineRunStatus @default(PENDING)
  startedAt        DateTime?
  completedAt      DateTime?
  durationMs       Int?
  recordsRead      Int?
  recordsWritten   Int?
  recordsSkipped   Int?
  errorCount       Int?              @default(0)
  errorMessage     String?
  logPath          String?           // đường dẫn log file trên MinIO hoặc hệ thống
  metadata         Json?             // step-level details nếu cần
  definition       PipelineDefinition @relation(fields: [definitionId], references: [id])
  qualityResults   DataQualityResult[]

  @@index([definitionId])
  @@index([status])
  @@index([startedAt])
  @@index([triggeredBy])
  @@map("pipeline_runs")
}

// --- Data Quality ---
// Định nghĩa một quy tắc kiểm tra chất lượng dữ liệu.
model DataQualityRule {
  id           String            @id @default(cuid())
  ruleCode     String            @unique // vd: DQ_STUDENT_NULL_NAME, DQ_SCORE_RANGE
  name         String
  description  String?
  ruleType     DataQualityRuleType // COMPLETENESS | UNIQUENESS | FK_INTEGRITY | VALID_RANGE | TIMELINESS | CONSISTENCY
  targetTable  String             // tên bảng cần kiểm tra
  targetColumn String?            // cột cụ thể, null = check toàn bảng
  ruleConfig   Json               // ngưỡng, điều kiện, SQL snippet tham chiếu
  severity     DQSeverity         // INFO | WARNING | ERROR | CRITICAL
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  results      DataQualityResult[]

  @@index([ruleType])
  @@index([targetTable])
  @@index([severity])
  @@index([isActive])
  @@map("data_quality_rules")
}

// Kết quả mỗi lần chạy kiểm tra chất lượng cho một rule.
model DataQualityResult {
  id            String          @id @default(cuid())
  ruleId        String
  pipelineRunId String?         // liên kết nếu chạy trong pipeline
  checkedAt     DateTime        @default(now())
  passed        Boolean
  totalChecked  Int
  failedRows    Int             @default(0)
  failRate      Float?          // failedRows / totalChecked
  severity      DQSeverity
  sampleData    Json?           // sample rows lỗi để debug
  note          String?
  rule          DataQualityRule @relation(fields: [ruleId], references: [id])
  pipelineRun   PipelineRun?    @relation(fields: [pipelineRunId], references: [id])

  @@index([ruleId])
  @@index([checkedAt])
  @@index([passed])
  @@index([pipelineRunId])
  @@map("data_quality_results")
}

// --- Warehouse Sync ---
// Theo dõi trạng thái đồng bộ từ PostgreSQL sang ClickHouse.
// Không lưu business data, chỉ lưu metadata trạng thái.
model WarehouseSyncJob {
  id            String            @id @default(cuid())
  sourceTable   String            // tên bảng PG nguồn
  targetDataset String            // tên dataset ClickHouse đích
  syncMode      WarehouseSyncMode // FULL | INCREMENTAL
  status        WarehoueSyncStatus @default(IDLE)
  lastSyncAt    DateTime?
  lastSyncRowCount Int?
  lastSyncDurationMs Int?
  watermarkField String?          // field dùng để incremental sync (vd: updatedAt)
  watermarkValue String?          // giá trị watermark lần cuối
  errorMessage  String?
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([sourceTable])
  @@index([status])
  @@index([lastSyncAt])
  @@map("warehouse_sync_jobs")
}

// --- Storage Bucket Config ---
// Chiến lược bucket MinIO theo module/domain. Không lưu objects.
model StorageBucketConfig {
  id              String    @id @default(cuid())
  bucketName      String    @unique
  moduleDomain    String    // vd: M02_PERSONNEL, M10_EDUCATION, M18_EXPORT, ARCHIVE
  description     String?
  retentionDays   Int?      // null = vĩnh viễn
  accessTier      StorageAccessTier // HOT | COLD | ARCHIVE
  lifecyclePolicy Json?     // MinIO lifecycle rule config
  maxSizeGb       Int?      // giới hạn kích thước bucket
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([moduleDomain])
  @@index([accessTier])
  @@map("storage_bucket_configs")
}

// --- Backup ---
// Ghi nhận mỗi lần chạy backup job.
model BackupJob {
  id           String          @id @default(cuid())
  backupType   BackupType      // POSTGRESQL_FULL | POSTGRESQL_INCREMENTAL | MINIO_CONFIG | AIRFLOW_DAGS | GRAFANA
  status       BackupJobStatus @default(PENDING)
  targetPath   String          // đường dẫn trên MinIO backup bucket
  triggeredBy  PipelineTrigger // MANUAL | SCHEDULED | API | EVENT
  requestedById String?        // user id nếu manual
  startedAt    DateTime?
  completedAt  DateTime?
  durationMs   Int?
  sizeBytes    BigInt?
  errorMessage String?
  artifacts    BackupArtifact[]
  restoreJobs  RestoreJob[]

  @@index([backupType])
  @@index([status])
  @@index([startedAt])
  @@index([triggeredBy])
  @@map("backup_jobs")
}

// Artifact vật lý của một backup job (file cụ thể trên MinIO).
model BackupArtifact {
  id            String     @id @default(cuid())
  jobId         String
  storagePath   String     // full path trên MinIO
  sizeBytes     BigInt
  checksumHash  String?    // sha256 để verify
  isVerified    Boolean    @default(false)
  verifiedAt    DateTime?
  retentionUntil DateTime? // null = giữ mãi
  metadata      Json?
  job           BackupJob  @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@index([retentionUntil])
  @@map("backup_artifacts")
}

// --- Restore ---
// Ghi nhận yêu cầu và kết quả restore từ backup.
model RestoreJob {
  id                 String            @id @default(cuid())
  backupJobId        String            // backup job nguồn
  targetEnvironment  String            // PRODUCTION | STAGING | DR_TEST
  requestedById      String            // bắt buộc — restore là thao tác nhạy cảm
  status             RestoreJobStatus  @default(REQUESTED)
  startedAt          DateTime?
  completedAt        DateTime?
  verificationStatus RestoreVerifyStatus @default(NOT_VERIFIED)
  verificationNote   String?
  errorMessage       String?
  notes              String?
  backupJob          BackupJob         @relation(fields: [backupJobId], references: [id])

  @@index([backupJobId])
  @@index([status])
  @@index([requestedById])
  @@index([startedAt])
  @@map("restore_jobs")
}

// --- Disaster Recovery ---
// Runbook DR và lịch diễn tập.
model DisasterRecoveryPlan {
  id           String                    @id @default(cuid())
  name         String
  description  String?
  rtoTargetMin Int                       // RTO mục tiêu tính bằng phút
  rpoTargetMin Int                       // RPO mục tiêu tính bằng phút
  runbookPath  String?                   // path file runbook (MinIO hoặc nội bộ)
  isActive     Boolean                   @default(true)
  createdById  String
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  exercises    DisasterRecoveryExercise[]

  @@index([isActive])
  @@map("disaster_recovery_plans")
}

// Ghi nhận kết quả từng lần diễn tập DR.
model DisasterRecoveryExercise {
  id             String               @id @default(cuid())
  planId         String
  exercisedAt    DateTime
  conductedById  String               // người điều hành diễn tập
  outcome        DRExerciseOutcome    // PASS | PARTIAL | FAIL
  rtoAchievedMin Int?                 // RTO thực tế đạt được
  rpoAchievedMin Int?                 // RPO thực tế đạt được
  findings       String?              // nhận xét, điểm cần cải thiện
  nextReviewDate DateTime?
  plan           DisasterRecoveryPlan @relation(fields: [planId], references: [id])

  @@index([planId])
  @@index([exercisedAt])
  @@index([outcome])
  @@map("disaster_recovery_exercises")
}

// --- Alert Threshold Policy ---
// Ngưỡng cảnh báo cấu hình được theo metric — tách khỏi ServiceAlert hard-code.
model MetricThresholdPolicy {
  id               String        @id @default(cuid())
  metricName       String        @unique // vd: pg_connection_pct, minio_disk_pct, api_p95_ms
  displayName      String
  description      String?
  warningThreshold Float
  criticalThreshold Float
  unit             String?       // %, ms, MB, connections...
  autoAction       String?       // mô tả action tự động khi vượt ngưỡng
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([isActive])
  @@map("metric_threshold_policies")
}

// =============================================================================
// END MODULE M12
// =============================================================================

// Yêu cầu cập nhật thông tin cá nhân (tự gửi, admin duyệt)
// Dùng cho function code REQUEST_MY_INFO_UPDATE — trường nhạy cảm không ghi thẳng vào User
model PersonalUpdateRequest {
  id             String    @id @default(cuid())
  userId         String
  fieldName      String                        // tên trường cần thay đổi, vd: "permanentAddress"
  currentValue   String?                       // giá trị hiện tại (để admin so sánh)
  requestedValue String                        // giá trị người dùng muốn đổi
  status         String    @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewedById   String?
  reviewedAt     DateTime?
  reviewNote     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation("PersonalUpdateRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy     User?     @relation("PersonalUpdateRequestReviewer", fields: [reviewedById], references: [id])

  @@index([userId, status])
  @@index([status, createdAt])
  @@map("personal_update_requests")
}

// ─── Rank Declaration (Khai báo quá trình lên quân hàm) ──────────────────────

model RankDeclaration {
  id                       String                @id @default(cuid())
  personnelId              String
  rankType                 String                // "OFFICER" | "SOLDIER"
  promotionType            PromotionType
  previousRank             String?
  newRank                  String?
  effectiveDate            DateTime
  decisionNumber           String?
  decisionDate             DateTime?
  previousPosition         String?
  newPosition              String?
  reason                   String?
  notes                    String?
  attachments              Json?
  declarationStatus        RankDeclarationStatus @default(DRAFT)
  workflowInstanceId       String?
  lockedAt                 DateTime?
  lockedBy                 String?
  declaredBy               String
  declaredOnBehalfOf       Boolean               @default(false)
  committedPromotionId     String?
  committedServiceRecordId String?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  createdBy                String?
  updatedBy                String?
  personnel                Personnel             @relation("RankDeclarationPersonnel", fields: [personnelId], references: [id], onDelete: Cascade)
  declarer                 User                  @relation("RankDeclarationDeclarer", fields: [declaredBy], references: [id])
  amendments               DeclarationAmendment[]

  @@index([personnelId])
  @@index([declarationStatus])
  @@index([workflowInstanceId])
  @@index([rankType])
  @@index([effectiveDate])
  @@index([createdAt])
  @@map("rank_declarations")
}

model DeclarationAmendment {
  id                 String          @id @default(cuid())
  declarationId      String
  requestedChanges   Json
  reason             String
  amendmentStatus    AmendmentStatus @default(DRAFT)
  workflowInstanceId String?
  requestedBy        String
  reviewedAt         DateTime?
  reviewedBy         String?
  reviewNote         String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  declaration        RankDeclaration @relation(fields: [declarationId], references: [id], onDelete: Cascade)
  requester          User            @relation("AmendmentRequester", fields: [requestedBy], references: [id])

  @@index([declarationId])
  @@index([amendmentStatus])
  @@map("declaration_amendments")
}

model PromotionProposal {
  id                 String                  @id @default(cuid())
  personnelId        String
  proposedById       String
  proposingUnitId    String
  proposedRank       String
  justification      String
  eligibilitySnap    Json?
  status             PromotionProposalStatus @default(DRAFT)
  workflowInstanceId String?
  respondedAt        DateTime?
  respondedBy        String?
  responseNote       String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  personnel          Personnel               @relation("PromotionProposalPersonnel", fields: [personnelId], references: [id], onDelete: Cascade)
  proposedBy         User                    @relation("PromotionProposalAuthor", fields: [proposedById], references: [id])
  proposingUnit      Unit                    @relation("UnitPromotionProposals", fields: [proposingUnitId], references: [id])

  @@index([personnelId])
  @@index([proposingUnitId])
  @@index([status])
  @@map("promotion_proposals")
}

enum RankDeclarationStatus {
  DRAFT
  PENDING_REVIEW
  UNDER_REVIEW
  APPROVED
  REJECTED
  RETURNED
  CANCELLED
}

enum AmendmentStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum PromotionProposalStatus {
  DRAFT
  SUBMITTED
  ACKNOWLEDGED
  APPROVED
  REJECTED
}
