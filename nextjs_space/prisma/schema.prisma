model HocVien {
  id                  String    @id @default(cuid())
  maHocVien           String    @unique
  hoTen               String
  ngaySinh            DateTime?
  gioiTinh            String?
  lop                 String?
  khoaHoc             String?
  nganh               String?
  giangVienHuongDanId String?
  email               String?
  dienThoai           String?
  diaChi              String?
  diemTrungBinh       Float     @default(0)
  trangThai           String    @default("Đang học")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  cohortId            String?
  classId             String?
  majorId             String?
  userId              String?   @unique

  // M07 – Academic performance status (computed từ GPA, cảnh báo học vụ)
  // Phân biệt với currentStatus: đây là trạng thái học lực, không phải lifecycle
  academicStatus AcademicPerformanceStatus @default(NORMAL)

  // M10 – Student Lifecycle fields
  currentStatus           EduStudentStatus @default(ACTIVE)
  studyMode               String? // lookup M19: STUDY_MODE
  currentProgramVersionId String?
  heDaoTao                String? // hình thức đào tạo (legacy from StudentProfile)
  khoaQuanLy              String? // khoa quản lý học viên
  trungDoi                String? // cấu trúc đơn vị quân sự
  daiDoi                  String? // cấu trúc đơn vị quân sự
  xepLoaiHocLuc           String? // xếp loại học lực tổng
  tongTinChi              Int? // tổng tín chỉ chương trình
  tinChiTichLuy           Int? // tín chỉ đã tích lũy
  ngayNhapHoc             DateTime? // ngày nhập học
  ngayTotNghiep           DateTime? // ngày tốt nghiệp
  lyDoNghiHoc             String? // lý do nghỉ học / thôi học
  deletedAt               DateTime? // soft delete
  deletedBy               String? // soft delete actor

  // M10 – Training system & battalion unit assignment
  trainingSystemUnitId    String? // FK → Unit (type='HE') — Hệ 1/2/3/4
  battalionUnitId         String? // FK → Unit (type='TIEU_DOAN')

  // Relations
  classEnrollments      ClassEnrollment[]
  examRegistrations     ExamRegistration[]
  conductRecords        StudentConductRecord[]
  academicWarnings      AcademicWarning[] // M10 – UC-57
  studentClass          StudentClass?            @relation(fields: [classId], references: [id])
  cohort                Cohort?                  @relation(fields: [cohortId], references: [id])
  giangVienHuongDan     FacultyProfile?          @relation(fields: [giangVienHuongDanId], references: [id])
  major                 SpecializationCatalog?   @relation("StudentMajor", fields: [majorId], references: [id])
  user                  User?                    @relation(fields: [userId], references: [id])
  currentProgramVersion ProgramVersion?          @relation(fields: [currentProgramVersionId], references: [id])
  ketQuaHocTap          KetQuaHocTap[]
  registrations         Registration[]
  thesisProjects        ThesisProject[] // M10 – UC-59
  graduationAudits      GraduationAudit[] // M10 – UC-60
  diplomaRecords        DiplomaRecord[] // M10 – UC-60
  repositoryItems       AcademicRepositoryItem[] // M10 – UC-61
  gpaHistories          StudentGpaHistory[] // M07 – GPA snapshot theo kỳ
  trainingSystemUnit    Unit?                    @relation("HocVienTrainingSystem", fields: [trainingSystemUnitId], references: [id])
  battalionUnit         Unit?                    @relation("HocVienBattalion", fields: [battalionUnitId], references: [id])

  @@index([maHocVien])
  @@index([userId])
  @@index([lop])
  @@index([khoaHoc])
  @@index([nganh])
  @@index([giangVienHuongDanId])
  @@index([cohortId])
  @@index([classId])
  @@index([majorId])
  @@index([currentStatus])
  @@index([currentProgramVersionId])
  @@index([deletedAt])
  @@index([trainingSystemUnitId])
  @@index([battalionUnitId])
  @@map("hoc_vien")
}

