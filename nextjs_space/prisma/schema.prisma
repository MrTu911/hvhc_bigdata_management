  contribution Float?
  project      NckhProject    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user         User           @relation("NckhMemberUser", fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("nckh_members")
}

model NckhMilestone {
  id            String              @id @default(cuid())
  projectId     String
  title         String
  dueDate       DateTime
  completedAt   DateTime?
  status        NckhMilestoneStatus @default(PENDING)
  note          String?
  attachmentUrl String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  project       NckhProject         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@map("nckh_milestones")
}

model NckhReview {
  id         String             @id @default(cuid())
  projectId  String
  reviewType NckhReviewType
  reviewDate DateTime
  score      Float?
  grade      String?
  comments   String?
  decision   NckhReviewDecision
  minutesUrl String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  project    NckhProject        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([reviewType])
  @@map("nckh_reviews")
}

model NckhPublication {
  id                 String                  @id @default(cuid())
  title              String
  titleEn            String?
  abstract           String?
  doi                String?
  isbn               String?
  issn               String?
  pubType            NckhPublicationType
  scopusQ            String?
  isISI              Boolean                 @default(false)
  isScopus           Boolean                 @default(false)
  journal            String?
  volume             String?
  issue              String?
  pages              String?
  publishedYear      Int?
  publisher          String?
  publishedAt        DateTime?
  projectId          String?
  authorId           String
  coAuthors          String?
  citationCount      Int                     @default(0)
  fullTextUrl        String?
  status             NckhPublicationStatus   @default(DRAFT)
  submittedAt        DateTime?
  reviewNote         String?
  reviewedAt         DateTime?
  reviewedById       String?
  unitId             String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  advisorName        String?
  authorsText        String?
  conferenceName     String?
  decisionNumber     String?
  defenseScore       Float?
  impactFactor       Float?
  keywords           String[]
  patentGrantDate    DateTime?
  patentNumber       String?
  proceedingName     String?
  ranking            String?
  storageLocation    String?
  publicationAuthors NckhPublicationAuthor[]
  author             User                    @relation("NckhPubAuthor", fields: [authorId], references: [id])
  reviewedBy         User?                   @relation("NckhPubReviewer", fields: [reviewedById], references: [id])
  project            NckhProject?            @relation(fields: [projectId], references: [id])

  @@index([authorId])
  @@index([projectId])
  @@index([pubType])
  @@index([publishedYear])
  @@index([isISI])
  @@index([isScopus])
  @@index([unitId])
  @@index([status])
  @@index([reviewedById])
  @@map("nckh_publications")
}

