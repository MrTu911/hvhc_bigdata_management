model NckhScientistProfile {
  id                 String                    @id @default(cuid())
  userId             String                    @unique
  hIndex             Int                       @default(0)
  i10Index           Int                       @default(0)
  totalCitations     Int                       @default(0)
  totalPublications  Int                       @default(0)
  primaryField       String?
  secondaryFields    String[]
  researchKeywords   String[]
  orcidId            String?
  scopusAuthorId     String?
  googleScholarId    String?
  bio                String?
  updatedAt          DateTime                  @updatedAt
  academicRank       String?
  awards             String[]
  createdAt          DateTime                  @default(now())
  degree             String?
  projectLeadCount   Int                       @default(0)
  projectMemberCount Int                       @default(0)
  researchFields     String[]
  researchVector     String?
  specialization     String?
  // Phase 2 additive fields (nullable/default – safe migration)
  sensitivityLevel   String                    @default("NORMAL") // NORMAL|CONFIDENTIAL
  researchAreaIds    String[] // FK refs → ScienceCatalog.id[]
  // Phase 3 additive fields (dual-write – backfill từ User.militaryId ?? employeeId)
  maso               String?                   @unique // Mã số cán bộ (denorm từ User, hỗ trợ external scientist)
  user               User                      @relation("NckhScientist", fields: [userId], references: [id])
  education          NckhScientistEducation[]
  career             NckhScientistCareer[]
  scientistAwards    NckhScientistAward[]
  councilMemberships ScientificCouncilMember[] @relation("CouncilMemberScientist")

  @@index([userId])
  @@index([maso])
  @@index([sensitivityLevel]) // sensitivity-guarded list
  @@map("nckh_scientist_profiles")
}

// ─────────────────────────────────────────────────────────────────────────────
// CSDL-KHQL – Phase 2: Sub-tables Nhà Khoa học (M02 mở rộng)
// Additive only – không drop/alter trường cũ của NckhScientistProfile
// ─────────────────────────────────────────────────────────────────────────────

/// Lịch sử học vấn của nhà khoa học.
model NckhScientistEducation {
  id          String               @id @default(cuid())
  scientistId String
  scientist   NckhScientistProfile @relation(fields: [scientistId], references: [id], onDelete: Cascade)
  degree      String // TSKH|TS|ThS|CN|KS|CK1|CK2
  major       String
  institution String
  country     String               @default("Việt Nam")
  yearFrom    Int
  yearTo      Int
  thesisTitle String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([scientistId])
  @@map("nckh_scientist_education")
}

/// Quá trình công tác / sự nghiệp của nhà khoa học.
model NckhScientistCareer {
  id          String               @id @default(cuid())
  scientistId String
  scientist   NckhScientistProfile @relation(fields: [scientistId], references: [id], onDelete: Cascade)
  position    String
  unitName    String
  yearFrom    Int
  yearTo      Int?
  isCurrent   Boolean              @default(false)
  // Sprint 02: true = ngoài HVHC (external institution); false = vị trí tại HVHC (canonical source: M02 WorkExperience)
  isExternal  Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([scientistId])
  @@map("nckh_scientist_career")
}

/// Giải thưởng KH của nhà khoa học (riêng với AwardsRecord chung của nhân sự).
model NckhScientistAward {
  id          String               @id @default(cuid())
  scientistId String
  scientist   NckhScientistProfile @relation(fields: [scientistId], references: [id], onDelete: Cascade)
  awardName   String
  level       String // MINISTRY|ACADEMY|DEPARTMENT|INTERNATIONAL
  year        Int
  projectId   String? // FK → NckhProject.id nếu gắn với đề tài
  description String?
  createdAt   DateTime             @default(now())

  @@index([scientistId])
  @@index([year])
  @@map("nckh_scientist_awards")
}

model NckhDuplicateCheckLog {
  id           String   @id @default(cuid())
  userId       String
  title        String
  keywords     String[]
  excludeId    String?
  risk         String
  matchCount   Int
  checkedCount Int
  matches      Json
  createdAt    DateTime @default(now())
  user         User     @relation("NckhDupCheckUser", fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("nckh_duplicate_check_logs")
}

