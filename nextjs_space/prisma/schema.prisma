generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model User {
  id                                  String                     @id @default(cuid())
  email                               String                     @unique
  emailVerified                       DateTime?
  name                                String
  password                            String
  role                                UserRole                   @default(HOC_VIEN)
  status                              UserStatus                 @default(ACTIVE)
  militaryId                          String?                    @unique
  rank                                String?
  department                          String?
  unit                                String?
  avatar                              String?
  phone                               String?
  dateOfBirth                         DateTime?
  gender                              String?
  address                             String?
  createdAt                           DateTime                   @default(now())
  updatedAt                           DateTime                   @updatedAt
  lastLoginAt                         DateTime?
  employeeId                          String?                    @unique
  endDate                             DateTime?
  personnelType                       PersonnelCategory?
  position                            String?
  startDate                           DateTime?
  unitId                              String?
  educationLevel                      String?
  joinDate                            DateTime?
  placeOfOrigin                       String?
  specialization                      String?
  workStatus                          WorkStatus                 @default(ACTIVE)
  birthPlace                          String?
  bloodType                           BloodType?
  citizenId                           String?
  dischargeDate                       DateTime?
  enlistmentDate                      DateTime?
  ethnicity                           String?
  managementLevel                     ManagementLevel?
  militaryIdNumber                    String?
  officerIdCard                       String?
  permanentAddress                    String?
  religion                            String?
  temporaryAddress                    String?
  personnelId                         String?                    @unique
  managementCategory                  ManagementCategory?
  partyJoinDate                       DateTime?
  partyPosition                       String?
  academicTitle                       String?
  technicalPosition                   String?
  technicalCertNumber                 String?
  technicalCertDate                   DateTime?
  technicalCertIssuer                 String?
  positionId                          String?
  ethnicityId                         String?
  religionId                          String?
  specializationId                    String?
  birthPlaceId                        String?
  placeOfOriginId                     String?
  authProvider                        String                     @default("LOCAL")
  failedLoginCount                    Int                        @default(0)
  lastSsoLoginAt                      DateTime?
  lockedUntil                         DateTime?
  mfaEnabled                          Boolean                    @default(false)
  mfaSecret                           String?
  accounts                            Account[]
  aiUsageLogs                         AIUsageLog[]
  authSessions                        AuthSession[]
  awardsRecords                       AwardsRecord[]
  careerHistories                     CareerHistory[]
  educationHistory                    EducationHistory[]
  facultyProfile                      FacultyProfile?
  familyRelations                     FamilyRelation[]
  foreignLanguageCerts                ForeignLanguageCert[]
  hocVien                             HocVien?
  insuranceInfo                       InsuranceInfo?
  medicalRecords                      MedicalRecord[]
  nckhDuplicateCheckLogs              NckhDuplicateCheckLog[]    @relation("NckhDupCheckUser")
  nckhMemberships                     NckhMember[]               @relation("NckhMemberUser")
  nckhProjectsAsPI                    NckhProject[]              @relation("NckhPI")
  nckhPublicationAuthorEntries        NckhPublicationAuthor[]    @relation("NckhPubAuthorEntry")
  nckhPublications                    NckhPublication[]          @relation("NckhPubAuthor")
  nckhPublicationsReviewed            NckhPublication[]          @relation("NckhPubReviewer")
  nckhScientistProfile                NckhScientistProfile?      @relation("NckhScientist")
  scienceCatalogsCreated              ScienceCatalog[]           @relation("ScienceCatalogCreator")
  partyMeetingsCreated                PartyMeeting[]             @relation("PartyMeetingCreator")
  partyInspectionsCreated             PartyInspectionTarget[]    @relation("PartyInspectionCreator")
  partyMember                         PartyMember?
  partyRecruitmentPipelines           PartyRecruitmentPipeline[]
  partyOrganizationsAsDeputySecretary PartyOrganization[]        @relation("PartyOrgDeputySecretary")
  partyOrganizationsAsSecretary       PartyOrganization[]        @relation("PartyOrgSecretary")
  personnelAIAnalyses                 PersonnelAIAnalysis[]
  personnelAttachments                PersonnelAttachment[]
  policyRecords                       PolicyRecord[]
  policyRequests                      PolicyRequest[]            @relation("PolicyRequester")
  scientificProfile                   ScientificProfile?
  scientificPublications              ScientificPublication[]
  scientificResearch                  ScientificResearch[]
  sessions                            Session[]
  studentProfile                      StudentProfile?
  nckhProjectWorkflowActions          NckhProjectWorkflowLog[]   @relation("WorkflowLogActor")
  libraryAccessLogs                   LibraryAccessLog[]
  libraryItemsCreated                 LibraryItem[]              @relation("LibraryItemCreator")
  researchBudgetsApproved             ResearchBudget[]           @relation("BudgetApprover")
  councilsAsChairman                  ScientificCouncil[]        @relation("CouncilChairman")
  councilsAsSecretary                 ScientificCouncil[]        @relation("CouncilSecretary")
  councilMemberships                  ScientificCouncilMember[]
  logs                                SystemLog[]
  technicalCertificates               TechnicalCertificate[]
  commandedUnits                      Unit[]                     @relation("UnitCommander")
  activities                          UserActivity[]
  grantedPermissions                  UserPermissionGrant[]      @relation("GrantedPermissions")
  permissionGrants                    UserPermissionGrant[]      @relation("UserPermissions")
  userPositions                       UserPosition[]             @relation("UserRBACPositions")
  birthPlaceRef                       AdministrativeUnit?        @relation("UserBirthPlace", fields: [birthPlaceId], references: [id])
  ethnicityRef                        Ethnicity?                 @relation("UserEthnicity", fields: [ethnicityId], references: [id])
  personnelProfile                    Personnel?                 @relation("PersonnelAccount", fields: [personnelId], references: [id])
  placeOfOriginRef                    AdministrativeUnit?        @relation("UserPlaceOfOrigin", fields: [placeOfOriginId], references: [id])
  positionRef                         Position?                  @relation("UserPositionRef", fields: [positionId], references: [id])
  religionRef                         Religion?                  @relation("UserReligion", fields: [religionId], references: [id])
  specializationRef                   SpecializationCatalog?     @relation("UserSpecialization", fields: [specializationId], references: [id])
  unitRelation                        Unit?                      @relation(fields: [unitId], references: [id])
  workExperience                      WorkExperience[]
  workflowActions                     WorkflowAction[]           @relation("WorkflowActionActor")
  dashboardLayouts                    DashboardUserLayout[]      @relation("UserDashboardLayouts")
  dashboardAccessLogs                 DashboardAccessLog[]       @relation("UserDashboardAccessLogs")
  // Phase 6: Lifecycle NCKH back-relations
  nckhProposalsAsPI                   NckhProposal[]             @relation("NckhProposalPI")
  nckhProposalsUnitApproved           NckhProposal[]             @relation("NckhProposalUnitApprover")
  nckhProposalsDeptApproved           NckhProposal[]             @relation("NckhProposalDeptApprover")
  nckhProposalsApproved               NckhProposal[]             @relation("NckhProposalApprover")
  nckhProposalReviews                 NckhProposalReview[]       @relation("NckhProposalReviewer")
  nckhProgressReportsSubmitted        NckhProgressReport[]       @relation("NckhReportSubmitter")
  nckhProgressReportsReviewed         NckhProgressReport[]       @relation("NckhReportReviewer")
  nckhMidtermReviewsApproved          NckhMidtermReview[]        @relation("NckhMidtermApprover")
  nckhExtensionsRequested             NckhExtension[]            @relation("NckhExtensionRequester")
  nckhExtensionsApproved              NckhExtension[]            @relation("NckhExtensionApprover")
  nckhClosures                        NckhClosure[]              @relation("NckhClosureBy")
  nckhLessonsLearned                  NckhLessonLearned[]        @relation("NckhLessonAuthor")
  nckhAcceptances                     NckhAcceptance[]           @relation("NckhAcceptanceBy")
  nckhCouncilMeetingsCreated          NckhCouncilMeeting[]       @relation("NckhMeetingCreator")
  // Phase 7: Finance back-relations
  nckhPurchaseOrdersApproved          NckhPurchaseOrder[]        @relation("NckhPOApprover")
  nckhPurchaseOrdersCreated           NckhPurchaseOrder[]        @relation("NckhPOCreator")
  nckhInvoicesPaid                    NckhInvoice[]              @relation("NckhInvoicePayer")
  nckhInvoicesCreated                 NckhInvoice[]              @relation("NckhInvoiceCreator")
  nckhExpensesSubmitted               NckhExpense[]              @relation("NckhExpenseSubmitter")
  nckhExpensesApproved                NckhExpense[]              @relation("NckhExpenseApprover")
  nckhGrantsCreated                   NckhGrant[]                @relation("NckhGrantCreator")
  // Phase 8: Chat + Collaboration back-relations
  nckhChatParticipations              NckhChatParticipant[]      @relation("NckhChatParticipant")
  nckhChatMessagesSent                NckhChatMessage[]          @relation("NckhChatSender")
  nckhCollaborationsCreated           NckhCollaboration[]        @relation("NckhCollabCreator")
  nckhCollaborationParticipations     NckhCollaborationParticipant[] @relation("NckhCollabParticipant")
  nckhCollaborationDocsUploaded       NckhCollaborationDocument[] @relation("NckhCollabDocUploader")
  scienceAttachmentsUploaded          ScienceAttachment[]         @relation("ScienceAttachmentUploader")
  personalUpdateRequests              PersonalUpdateRequest[]     @relation("PersonalUpdateRequestUser")
  personalUpdateRequestsReviewed      PersonalUpdateRequest[]     @relation("PersonalUpdateRequestReviewer")
  rankDeclarationsCreated             RankDeclaration[]           @relation("RankDeclarationDeclarer")
  declarationAmendmentsRequested      DeclarationAmendment[]      @relation("AmendmentRequester")
  promotionProposalsCreated           PromotionProposal[]         @relation("PromotionProposalAuthor")

  @@index([email])
  @@index([role])
  @@index([militaryId])
  @@index([employeeId])
  @@index([personnelType])
  @@index([unitId])
  @@index([lastLoginAt])
  @@index([status])
  @@index([workStatus])
  @@index([personnelId])
  @@map("users")
}

model AuthSession {
  id             String    @id @default(cuid())
  userId         String
  token          String    @unique
  ipAddress      String?
  userAgent      String?
  deviceName     String?
  isActive       Boolean   @default(true)
  loginAt        DateTime  @default(now())
  lastActivityAt DateTime  @default(now())
  expiresAt      DateTime
  revokedAt      DateTime?
  revokedReason  String?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([isActive])
  @@index([expiresAt])
  @@map("auth_sessions")
}

/// M07 – Hồ sơ giảng viên. Source of truth cho thông tin giảng dạy chuyên môn.
/// Nhân thân, học vị căn cước lấy từ M02 qua personnelId.
/// KHÔNG duplicate dữ liệu Personnel – chỉ extend thêm trường chuyên ngành giảng dạy.
model FacultyProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  departmentId       String?
  academicRank       String?
  academicDegree     String?
  specialization     String?
  teachingSubjects   Json?
  researchInterests  String?
  researchProjects   Int      @default(0)
  publications       Int      @default(0)
  citations          Int      @default(0)
  teachingExperience Int      @default(0)
  industryExperience Int      @default(0)
  biography          String?
  achievements       Json?
  certifications     Json?
  linkedinUrl        String?
  googleScholarUrl   String?
  researchGateUrl    String?
  orcidId            String?
  isActive           Boolean  @default(true)
  isPublic           Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  unitId             String?

  // M07 – Link to M02 Personnel (optional: chỉ giảng viên quân nhân)
  personnelId      String?   @unique
  // M07 – Chức danh giảng dạy: lookup M19 TEACHING_POSITION
  teachingPosition String?
  // M07 – Ngày bắt đầu giảng dạy tại HVHC
  teachingStart    DateTime?
  // M07 – Định mức giờ dạy/tuần (mặc định 16 giờ)
  weeklyHoursLimit Float     @default(16)
  // M07 – Thỉnh giảng ngoài HV: đơn vị công tác gốc (null = cán bộ nội bộ)
  homeInstitution  String?
  // M07 – Thỉnh giảng ngoài HV: ngày hết hạn hợp đồng thỉnh giảng
  contractEndDate  DateTime?

  researchProjectsList ResearchProject[]
  teachingSubjectsList TeachingSubject[]
  classSections        ClassSection[]            @relation("ClassSectionFaculty")
  courses              Course[]
  examsInvigilated     Exam[]
  unit                 Unit?                     @relation("FacultyProfileUnit", fields: [unitId], references: [id])
  user                 User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  hocVienHuongDan      HocVien[]
  trainingSessions     TrainingSession[]         @relation("SessionFaculty")
  thesisAdvised        ThesisProject[]           @relation("ThesisAdvisor")
  thesisReviewed       ThesisProject[]           @relation("ThesisReviewer")
  // M07 – Snapshot/read-model relations
  eisScores            FacultyEISScore[]
  workloadSnapshots    FacultyWorkloadSnapshot[]

  @@index([userId])
  @@index([departmentId])
  @@index([unitId])
  @@index([academicRank])
  @@index([academicDegree])
  @@index([personnelId])
  @@index([teachingPosition])
  @@map("faculty_profiles")
}

model Department {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  shortName   String?
  fullName    String?
  parentId    String?
  level       Int
  description String?
  address     String?
  phone       String?
  email       String?
  latitude    Float?
  longitude   Float?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
  @@index([parentId])
  @@map("departments")
}

model BigDataService {
  id          String          @id @default(cuid())
  name        String
  type        ServiceType
  status      ServiceStatus   @default(UNKNOWN)
  host        String
  port        Int
  url         String?
  username    String?
  password    String?
  lastChecked DateTime?
  uptime      Float?          @default(0)
  version     String?
  description String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  alerts      ServiceAlert[]
  metrics     ServiceMetric[]

  @@index([type])
  @@index([status])
  @@map("bigdata_services")
}

model ServiceMetric {
  id          String         @id @default(cuid())
  serviceId   String
  metricName  String
  metricValue Float
  unit        String?
  cpuUsage    Float?
  memoryUsage Float?
  diskUsage   Float?
  networkIn   Float?
  networkOut  Float?
  timestamp   DateTime       @default(now())
  service     BigDataService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([metricName])
  @@index([timestamp])
  @@map("service_metrics")
}

model ServiceAlert {
  id             String         @id @default(cuid())
  serviceId      String
  title          String
  message        String
  severity       AlertSeverity
  status         AlertStatus    @default(ACTIVE)
  triggeredAt    DateTime       @default(now())
  acknowledgedAt DateTime?
  acknowledgedBy String?
  resolvedAt     DateTime?
  resolvedBy     String?
  metadata       Json?
  service        BigDataService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([status])
  @@index([severity])
  @@map("service_alerts")
}

model AirflowDag {
  id           String    @id @default(cuid())
  dagId        String    @unique
  dagName      String
  description  String?
  status       DagStatus
  isPaused     Boolean   @default(false)
  lastRunTime  DateTime?
  nextRunTime  DateTime?
  successCount Int       @default(0)
  failedCount  Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  runs         DagRun[]

  @@index([dagId])
  @@index([status])
  @@map("airflow_dags")
}

model DagRun {
  id        String     @id @default(cuid())
  dagId     String
  runId     String     @unique
  status    DagStatus
  startDate DateTime
  endDate   DateTime?
  duration  Float?
  logUrl    String?
  metadata  Json?
  dag       AirflowDag @relation(fields: [dagId], references: [id], onDelete: Cascade)

  @@index([dagId])
  @@index([status])
  @@index([startDate])
  @@map("dag_runs")
}

model SystemLog {
  id          String      @id @default(cuid())
  userId      String?
  level       LogLevel
  category    LogCategory
  action      String
  description String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())
  user        User?       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([level])
  @@index([category])
  @@index([createdAt])
  @@map("system_logs")
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  action    String
  resource  String?
  details   String?
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
  @@map("user_activities")
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  category    String
  description String?
  isEditable  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([category])
  @@map("system_configs")
}

model ResearchFile {
  id               String              @id @default(cuid())
  fileName         String
  originalName     String
  fileSize         Int
  fileType         FileType
  mimeType         String
  bucketName       String
  objectKey        String
  fileUrl          String?
  uploadedBy       String
  department       String?
  researchArea     String?
  tags             String[]
  status           FileStatus          @default(UPLOADING)
  title            String?
  description      String?
  keywords         String[]
  downloadCount    Int                 @default(0)
  viewCount        Int                 @default(0)
  uploadedAt       DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  checksum         String?
  classification   ClassificationLevel @default(INTERNAL)
  digitalSignature String?
  isLatest         Boolean             @default(true)
  parentId         String?
  version          Int                 @default(1)
  accessLogs       FileAccessLog[]

  @@index([uploadedBy])
  @@index([fileType])
  @@index([department])
  @@index([status])
  @@index([classification])
  @@index([parentId])
  @@index([uploadedAt])
  @@map("research_files")
}

model FileAccessLog {
  id           String       @id @default(cuid())
  fileId       String
  userId       String
  action       AccessAction
  ipAddress    String?
  userAgent    String?
  location     String?
  success      Boolean      @default(true)
  errorMessage String?
  metadata     Json?
  timestamp    DateTime     @default(now())
  file         ResearchFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([userId])
  @@index([action])
  @@index([timestamp])
  @@map("file_access_logs")
}

model DataQuery {
  id            String      @id @default(cuid())
  queryText     String
  queryType     QueryType
  executedBy    String
  department    String?
  status        QueryStatus @default(PENDING)
  executionTime Float?
  rowsReturned  Int?
  dataSize      Float?
  resultUrl     String?
  errorMessage  String?
  parameters    Json?
  submittedAt   DateTime    @default(now())
  startedAt     DateTime?
  completedAt   DateTime?

  @@index([executedBy])
  @@index([queryType])
  @@index([status])
  @@index([submittedAt])
  @@map("data_queries")
}

model AnalyticsSummary {
  id              String   @id @default(cuid())
  summaryType     String
  summaryDate     DateTime
  totalUsers      Int
  activeUsers     Int
  newUsers        Int
  totalServices   Int
  healthyServices Int
  downServices    Int
  totalFiles      Int
  totalQueries    Int
  totalStorage    Float
  dataUploaded    Float
  queriesExecuted Int
  avgQueryTime    Float
  avgCpuUsage     Float
  avgMemoryUsage  Float
  avgDiskUsage    Float
  metadata        Json?
  createdAt       DateTime @default(now())

  @@unique([summaryType, summaryDate])
  @@index([summaryType])
  @@index([summaryDate])
  @@map("analytics_summaries")
}

model MLModel {
  id                  String              @id @default(cuid())
  name                String
  description         String?
  modelType           ModelType
  framework           ModelFramework
  ownerId             String
  department          String?
  researchArea        String?
  classification      ClassificationLevel @default(INTERNAL)
  trainingDatasetId   String?
  validationDatasetId String?
  version             String              @default("1.0.0")
  parentId            String?
  isLatest            Boolean             @default(true)
  bucketName          String?
  modelPath           String?
  configPath          String?
  hyperparameters     Json?
  trainingConfig      Json?
  accuracy            Float?
  precision           Float?
  recall              Float?
  f1Score             Float?
  loss                Float?
  customMetrics       Json?
  status              ModelStatus         @default(DRAFT)
  trainingStartedAt   DateTime?
  trainingCompletedAt DateTime?
  trainingDuration    Float?
  deployedAt          DateTime?
  deploymentUrl       String?
  predictionCount     Int                 @default(0)
  tags                String[]
  metadata            Json?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  predictions         ModelPrediction[]
  trainingJobs        TrainingJob[]

  @@index([ownerId])
  @@index([modelType])
  @@index([framework])
  @@index([status])
  @@index([classification])
  @@index([createdAt])
  @@map("ml_models")
}

model TrainingJob {
  id                String    @id @default(cuid())
  modelId           String
  jobName           String
  jobType           String    @default("training")
  config            Json?
  hyperparameters   Json?
  trainingDataset   String?
  validationDataset String?
  testDataset       String?
  status            JobStatus @default(QUEUED)
  gpuAllocated      Int?
  cpuAllocated      Int?
  memoryAllocated   Float?
  progress          Float     @default(0)
  currentEpoch      Int?
  totalEpochs       Int?
  startedAt         DateTime?
  completedAt       DateTime?
  duration          Float?
  finalMetrics      Json?
  logPath           String?
  errorMessage      String?
  errorStack        String?
  retryCount        Int       @default(0)
  maxRetries        Int       @default(3)
  metadata          Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  model             MLModel   @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@index([status])
  @@index([startedAt])
  @@map("training_jobs")
}

model ModelPrediction {
  id            String   @id @default(cuid())
  modelId       String
  userId        String?
  inputData     Json
  outputData    Json
  inferenceTime Float
  feedback      String?
  isCorrect     Boolean?
  timestamp     DateTime @default(now())
  model         MLModel  @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@index([userId])
  @@index([timestamp])
  @@map("model_predictions")
}

model DataPipeline {
  id               String         @id @default(cuid())
  name             String
  description      String?
  pipelineType     String
  inputDataset     String
  outputDataset    String?
  steps            Json
  parameters       Json?
  status           PipelineStatus @default(PENDING)
  startedAt        DateTime?
  completedAt      DateTime?
  duration         Float?
  recordsProcessed Int?
  errorCount       Int?
  logPath          String?
  errorMessage     String?
  createdBy        String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([status])
  @@index([createdBy])
  @@index([createdAt])
  @@map("data_pipelines")
}

model experiment_artifacts {
  id            String         @id @db.VarChar(255)
  experiment_id String         @db.VarChar(255)
  artifact_name String         @db.VarChar(255)
  artifact_type String?        @db.VarChar(50)
  artifact_path String?
  file_size     BigInt?
  created_at    DateTime?      @default(now()) @db.Timestamp(6)
  experiment    ml_experiments @relation(fields: [experiment_id], references: [id], onDelete: Cascade)

  @@index([experiment_id], map: "idx_artifacts_experiment")
}

model experiment_metrics {
  id            String         @id @db.VarChar(255)
  experiment_id String         @db.VarChar(255)
  metric_name   String         @db.VarChar(255)
  metric_value  Float
  step          Int?           @default(0)
  epoch         Int?           @default(0)
  timestamp     DateTime?      @default(now()) @db.Timestamp(6)
