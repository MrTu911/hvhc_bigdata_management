/**
 * GradeRecord – Điểm gắn với Registration (luồng đăng ký môn / thi riêng).
 * ĐÂY KHÔNG PHẢI GradeRecord của M10 UC-56.
 * Source of truth điểm học phần M10 là ClassEnrollment (có ScoreHistory audit trail).
 * Model này chỉ dùng cho Registration flow (exam registration, legacy course registration).
 * Không mở rộng thêm; không ghi điểm học phần mới vào đây.
 */
/// ─────────────────────────────────────────────────────────────────────────────
/// GradeRecord – SCOPE: Registration flow only (Đăng ký môn học / kỳ thi).
///
/// ĐÂY KHÔNG PHẢI model điểm học phần của M10 UC-56.
/// M10 UC-56 (nhập điểm, lịch sử điểm, finalize) dùng ClassEnrollment +
/// ScoreHistory — KHÔNG dùng model này.
///
/// Nhầm lẫn phổ biến: design doc dùng tên "GradeRecord" → ánh xạ vào
/// ClassEnrollment trong codebase, không phải model này.
/// ─────────────────────────────────────────────────────────────────────────────
model GradeRecord {
  id              String       @id @default(cuid())
  registrationId  String       @unique
  midtermScore    Float?
  finalScore      Float?
  assignmentScore Float?
  attendanceScore Float?
  totalScore      Float?
  letterGrade     String?
  status          GradeStatus  @default(PENDING)
  gradedBy        String?
  gradedAt        DateTime?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  registration    Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([letterGrade])
  @@index([gradedAt])
  @@map("grade_records")
}

/// ─────────────────────────────────────────────────────────────────────────────
/// AcademicYear / Term – QUYẾT ĐỊNH KIẾN TRÚC: TỰ QUẢN LÝ (không sync M19).
///
/// Lý do: M19 quản lý lookup codes/danh mục (phân loại, tra cứu).
/// AcademicYear và Term là operational entities cần: startDate/endDate,
/// isCurrent flag, quan hệ cụ thể với ClassSection / CurriculumPlan.
/// M19 không có cấu trúc phù hợp cho thực thể thời gian vận hành này.
///
/// String field `academicYear` trên các model khác (VD: StudentConductRecord,
/// AcademicWarning) là denormalized copy của AcademicYear.code —
/// cố ý để tránh JOIN khi chỉ cần hiển thị mã năm học.
/// ─────────────────────────────────────────────────────────────────────────────
model AcademicYear {
  id              String           @id @default(cuid())
  code            String           @unique
  name            String
  startDate       DateTime
  endDate         DateTime
  isCurrent       Boolean          @default(false)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  curriculumPlans CurriculumPlan[]
  terms           Term[]

  @@index([code])
  @@index([isCurrent])
  @@map("academic_years")
}

model Term {
  id                String            @id @default(cuid())
  code              String            @unique
  name              String
  academicYearId    String
  termNumber        Int               @default(1)
  startDate         DateTime
  endDate           DateTime
  registrationStart DateTime?
  registrationEnd   DateTime?
  isCurrent         Boolean           @default(false)
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  classSections     ClassSection[]
  examPlans         ExamPlan[]
  academicYear      AcademicYear      @relation(fields: [academicYearId], references: [id])
  trainingSessions  TrainingSession[]

  @@index([code])
  @@index([academicYearId])
  @@index([isCurrent])
  @@map("terms")
}

