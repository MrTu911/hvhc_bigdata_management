model ClassSection {
  id                 String             @id @default(cuid())
  code               String             @unique
  name               String
  curriculumCourseId String?
  termId             String
  facultyId          String?
  roomId             String?
  maxStudents        Int                @default(50)
  currentStudents    Int                @default(0)
  schedule           String?
  dayOfWeek          Int?
  startPeriod        Int?
  endPeriod          Int?
  startDate          DateTime?
  endDate            DateTime?
  status             ClassSectionStatus @default(OPEN)
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  enrollments        ClassEnrollment[]
  curriculumCourse   CurriculumCourse?  @relation(fields: [curriculumCourseId], references: [id])
