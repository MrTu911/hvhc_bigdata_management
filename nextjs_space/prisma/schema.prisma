model NckhProject {
  id                      String                       @id @default(cuid())
  projectCode             String                       @unique
  title                   String
  titleEn                 String?
  abstract                String?
  keywords                String[]
  category                NckhCategory
  field                   NckhField
  researchType            NckhType
  status                  NckhProjectStatus            @default(DRAFT)
  phase                   NckhProjectPhase             @default(PROPOSAL)
  startDate               DateTime?
  endDate                 DateTime?
  actualEndDate           DateTime?
  budgetRequested         Float?
  budgetApproved          Float?
  budgetUsed              Float?
  budgetYear              Int?
  principalInvestigatorId String
  unitId                  String?
  bqpProjectCode          String?
  approvedAt              DateTime?
  approvedBy              String?
  approverNote            String?
  rejectedAt              DateTime?
  rejectedBy              String?
  rejectReason            String?
  completionScore         Float?
  completionGrade         String?
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt
  submittedAt             DateTime?
  submittedBy             String?
  members                 NckhMember[]
  milestones              NckhMilestone[]
  principalInvestigator   User                         @relation("NckhPI", fields: [principalInvestigatorId], references: [id])
  unit                    Unit?                        @relation("NckhProjectUnit", fields: [unitId], references: [id])
  publications            NckhPublication[]
  reviews                 NckhReview[]
  budget                  ResearchBudget?
  councils                ScientificCouncil[]
  // Phase 3 additive fields
  sensitivity             String                       @default("NORMAL") // NORMAL|CONFIDENTIAL|SECRET
  embedding               Unsupported("vector(1536)")? // pgvector Phase 5 – requires postgresql-16-pgvector
  fundSourceId            String? // FK → ScienceCatalog (type=FUND_SOURCE)
  fundSource              ScienceCatalog?              @relation("ProjectFundSource", fields: [fundSourceId], references: [id])
  workflowLogs            NckhProjectWorkflowLog[]
  // Sprint 02 additive – nullable until M13 wiring is live (Sprint 03)
  workflowInstanceId      String? // FK → WorkflowInstance.id (plain string, no Prisma relation yet)
  // Phase 6: Lifecycle NCKH
  proposal                NckhProposal?
  progressReports         NckhProgressReport[]       @relation("NckhProjectReports")
  midtermReview           NckhMidtermReview?         @relation("NckhMidtermReview")
  extensions              NckhExtension[]            @relation("NckhProjectExtensions")
  closure                 NckhClosure?               @relation("NckhClosure")
  lessonsLearned          NckhLessonLearned[]        @relation("NckhLessonsLearned")
  acceptance              NckhAcceptance?            @relation("NckhAcceptance")
  // Phase 7: Finance granular
  purchaseOrders          NckhPurchaseOrder[]        @relation("NckhProjectPOs")
  invoices                NckhInvoice[]              @relation("NckhProjectInvoices")
  expenses                NckhExpense[]              @relation("NckhProjectExpenses")
  grants                  NckhGrant[]                @relation("NckhProjectGrants")
  // Phase 8: Chat + Collaboration
  chatRoom                NckhChatRoom?              @relation("NckhProjectChat")
  collaborations          NckhCollaboration[]        @relation("NckhProjectCollabs")
  // M07 back-relation: M07 ResearchProject tự khai của giảng viên liên kết tới đây
  facultyResearchProject  ResearchProject?           @relation("ResearchProjectNckh")

  @@index([principalInvestigatorId])
  @@index([submittedBy])
  @@index([unitId])
  @@index([status])
  @@index([phase])
  @@index([category])
  @@index([field])
  @@index([budgetYear])
  @@index([fundSourceId])
  @@index([endDate]) // deadline alert queries
  @@index([sensitivity]) // sensitivity-guarded list
  @@map("nckh_projects")
}

model NckhMember {
  id           String         @id @default(cuid())
  projectId    String
  userId       String
  role         NckhMemberRole
  joinDate     DateTime       @default(now())
