  @@index([curriculumCourseId])
  @@index([termId])
  @@index([facultyId])
  @@index([roomId])
  @@index([status])
  // M10 – UC-54: Composite indexes cho conflict-check engine
  @@index([termId, dayOfWeek, startPeriod, endPeriod]) // phát hiện trùng giờ
  @@index([termId, roomId]) // phát hiện trùng phòng
  @@index([termId, facultyId]) // phát hiện trùng giảng viên
  @@map("class_sections")
}

model ClassEnrollment {
  id              String              @id @default(cuid())
