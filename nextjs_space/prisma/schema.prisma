// M10 – UC-58: Điểm rèn luyện, khen thưởng, kỷ luật người học theo học kỳ
model StudentConductRecord {
  id                String    @id @default(cuid())
  hocVienId         String
  academicYear      String // mã năm học, tham chiếu AcademicYear.code
  semesterCode      String // mã học kỳ, tham chiếu Term.code
  conductScore      Float
  conductGrade      String? // xếp loại: lookup M19 CONDUCT_GRADE
  rewardSummary     String? // tóm tắt khen thưởng
  disciplineSummary String? // tóm tắt kỷ luật
  approvedBy        String? // userId người duyệt
  approvedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  hocVien HocVien @relation(fields: [hocVienId], references: [id], onDelete: Cascade)

  @@unique([hocVienId, academicYear, semesterCode])
  @@index([hocVienId])
  @@index([academicYear, semesterCode])
  @@map("student_conduct_records")
}

/**
 * M10 – UC-56: Lịch sử thay đổi điểm (MANDATORY audit trail)
 * Mỗi lần PATCH ClassEnrollment scores → phải tạo 1 record ScoreHistory
 * trong cùng transaction.
 */
model ScoreHistory {
  id           String          @id @default(cuid())
  enrollmentId String
  changedBy    String? // userId người sửa
  oldValues    Json // { attendanceScore, midtermScore, finalScore, ... }
  newValues    Json // giá trị sau sửa
  reason       String? // lý do sửa điểm
  changedAt    DateTime        @default(now())
  enrollment   ClassEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([enrollmentId])
  @@index([changedAt])
  @@map("score_histories")
}

/**
 * M10 – UC-57: Cảnh báo học vụ
 * Upsert pattern theo (hocVienId, academicYear, semesterCode)
 * Trigger thủ công (manual) trong Phase 1, auto sau.
 */
model AcademicWarning {
  id                String               @id @default(cuid())
  hocVienId         String
  academicYear      String // VD: "2025-2026"
  semesterCode      String // VD: "HK1"
  warningLevel      AcademicWarningLevel
  warningReasonJson Json? // { gpa, failedCredits, absenceRate, ... }
  suggestedAction   String?
  isResolved        Boolean              @default(false)
  resolvedAt        DateTime?
  resolvedBy        String?
  generatedAt       DateTime             @default(now())
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  hocVien           HocVien              @relation(fields: [hocVienId], references: [id], onDelete: Cascade)

  @@unique([hocVienId, academicYear, semesterCode])
  @@index([hocVienId])
  @@index([academicYear, semesterCode])
  @@index([warningLevel])
  @@index([isResolved])
  @@map("academic_warnings")
}

