/// Quản lý mẫu biểu báo cáo – Template Library
/// Versioning: self-reference qua parentId (root: parentId=null, isLatest=true)
model ReportTemplate {
  id            String                   @id @default(cuid())
  code          String // unique per (code, version) — xem @@unique bên dưới
  name          String
  description   String?
  moduleSource  String[]
  outputFormats String[]
  fileKey       String?
  version       Int                      @default(1)
  isActive      Boolean                  @default(true)
  isLatest      Boolean                  @default(true)
  rbacCode      String
  dataMap       Json                     @default("{}")
  placeholders  Json? // placeholder scan result từ file upload
  changeNote    String? // ghi chú lý do tạo version mới
  category      String?
  parentId      String?
  createdBy     String
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  deletedAt     DateTime? // soft delete — null = chưa xóa
  deletedBy     String? // user id thực hiện xóa
  exportJobs    ExportJob[]
  parent        ReportTemplate?          @relation("TemplateVersions", fields: [parentId], references: [id])
  versions      ReportTemplate[]         @relation("TemplateVersions")
  schedules     TemplateSchedule[]
  analytics     TemplateAnalyticsDaily[]

  @@unique([code, version])
  @@index([code])
  @@index([category])
  @@index([isActive])
  @@index([isLatest])
  @@index([createdBy])
  @@index([deletedAt])
  @@map("report_templates")
}

/// Theo dõi tiến trình xuất file – Export Job Tracking
model ExportJob {
  id              String          @id @default(cuid())
  templateId      String
  templateVersion Int
  requestedBy     String
  entityIds       String[]
  entityType      String
  outputFormat    String
  status          ExportJobStatus @default(PENDING)
  progress        Int             @default(0)
  successCount    Int             @default(0)
  failCount       Int             @default(0)
  errors          Json?
  outputKey       String?
  signedUrl       String?
  urlExpiresAt    DateTime?
  callerType      String?
  retryCount      Int             @default(0)
  parentJobId     String?
  createdAt       DateTime        @default(now())
  completedAt     DateTime?
  template        ReportTemplate  @relation(fields: [templateId], references: [id])
  parentJob       ExportJob?      @relation("ExportJobRetryChain", fields: [parentJobId], references: [id])
  retries         ExportJob[]     @relation("ExportJobRetryChain")

  @@index([requestedBy])
  @@index([templateId])
  @@index([status])
  @@index([createdAt])
  @@index([parentJobId])
  @@map("export_jobs")
}

