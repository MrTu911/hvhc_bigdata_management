generator client {
  provider      = "prisma-client-js"
  output        = "/home/ubuntu/hvhc_bigdata_management/nextjs_space/node_modules/.prisma/client"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  emailVerified          DateTime?
  name                   String
  password               String
  role                   UserRole                @default(HOC_VIEN)
  status                 UserStatus              @default(ACTIVE)
  militaryId             String?                 @unique
  rank                   String?
  department             String?
  unit                   String?
  avatar                 String?
  phone                  String?
  dateOfBirth            DateTime?
  gender                 String?
  address                String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  lastLoginAt            DateTime?
  employeeId             String?                 @unique
  endDate                DateTime?
  personnelType          PersonnelCategory?
  position               String?
  startDate              DateTime?
  unitId                 String?
  educationLevel         String?
  joinDate               DateTime?
  placeOfOrigin          String?
  specialization         String?
  workStatus             WorkStatus              @default(ACTIVE)
  birthPlace             String?
  bloodType              BloodType?
  citizenId              String?
  dischargeDate          DateTime?
  enlistmentDate         DateTime?
  ethnicity              String?
  managementLevel        ManagementLevel?
  militaryIdNumber       String?
  officerIdCard          String?
  permanentAddress       String?
  religion               String?
  temporaryAddress       String?
  personnelId            String?                 @unique
  managementCategory     ManagementCategory?
  partyJoinDate          DateTime?
  partyPosition          String?
  accounts               Account[]
  awardsRecords          AwardsRecord[]
  educationHistory       EducationHistory[]
  facultyProfile         FacultyProfile?
  insuranceInfo          InsuranceInfo?
  medicalRecords         MedicalRecord[]
  partyMember            PartyMember?
  personnelAIAnalyses    PersonnelAIAnalysis[]
  personnelAttachments   PersonnelAttachment[]
  policyRecords          PolicyRecord[]
  policyRequests         PolicyRequest[]         @relation("PolicyRequester")
  scientificProfile      ScientificProfile?
  scientificPublications ScientificPublication[]
  scientificResearch     ScientificResearch[]
  sessions               Session[]
  studentProfile         StudentProfile?
  logs                   SystemLog[]
  commandedUnits         Unit[]                  @relation("UnitCommander")
  activities             UserActivity[]
  grantedPermissions     UserPermissionGrant[]   @relation("GrantedPermissions")
  permissionGrants       UserPermissionGrant[]   @relation("UserPermissions")
  userPositions          UserPosition[]          @relation("UserRBACPositions")
  personnelProfile       Personnel?              @relation("PersonnelAccount", fields: [personnelId], references: [id])
  unitRelation           Unit?                   @relation(fields: [unitId], references: [id])
  workExperience         WorkExperience[]

  @@index([email])
  @@index([role])
  @@index([militaryId])
  @@index([employeeId])
  @@index([personnelType])
  @@index([unitId])
  @@index([lastLoginAt])
  @@index([status])
  @@index([workStatus])
  @@index([personnelId])
  @@map("users")
}

model FacultyProfile {
  id                   String            @id @default(cuid())
  userId               String            @unique
  departmentId         String?
  academicRank         String?
  academicDegree       String?
  specialization       String?
  teachingSubjects     Json?
  researchInterests    String?
  researchProjects     Int               @default(0)
  publications         Int               @default(0)
  citations            Int               @default(0)
  teachingExperience   Int               @default(0)
  industryExperience   Int               @default(0)
  biography            String?
  achievements         Json?
  certifications       Json?
  linkedinUrl          String?
  googleScholarUrl     String?
  researchGateUrl      String?
  orcidId              String?
  isActive             Boolean           @default(true)
  isPublic             Boolean           @default(false)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  unitId               String?
  researchProjectsList ResearchProject[]
  teachingSubjectsList TeachingSubject[]
  courses              Course[]
  examsInvigilated     Exam[]
  unit                 Unit?             @relation("FacultyProfileUnit", fields: [unitId], references: [id])
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  hocVienHuongDan      HocVien[]

  @@index([userId])
  @@index([departmentId])
  @@index([unitId])
  @@index([academicRank])
  @@index([academicDegree])
  @@map("faculty_profiles")
}

model Department {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  shortName   String?
  fullName    String?
  parentId    String?
  level       Int
  description String?
  address     String?
  phone       String?
  email       String?
  latitude    Float?
  longitude   Float?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
  @@index([parentId])
  @@map("departments")
}

model BigDataService {
  id          String          @id @default(cuid())
  name        String
  type        ServiceType
  status      ServiceStatus   @default(UNKNOWN)
  host        String
  port        Int
  url         String?
  username    String?
  password    String?
  lastChecked DateTime?
  uptime      Float?          @default(0)
  version     String?
  description String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  alerts      ServiceAlert[]
  metrics     ServiceMetric[]

  @@index([type])
  @@index([status])
  @@map("bigdata_services")
}

model ServiceMetric {
  id          String         @id @default(cuid())
  serviceId   String
  metricName  String
  metricValue Float
  unit        String?
  cpuUsage    Float?
  memoryUsage Float?
  diskUsage   Float?
  networkIn   Float?
  networkOut  Float?
  timestamp   DateTime       @default(now())
  service     BigDataService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([metricName])
  @@index([timestamp])
  @@map("service_metrics")
}

model ServiceAlert {
  id             String         @id @default(cuid())
  serviceId      String
  title          String
  message        String
  severity       AlertSeverity
  status         AlertStatus    @default(ACTIVE)
  triggeredAt    DateTime       @default(now())
  acknowledgedAt DateTime?
  acknowledgedBy String?
  resolvedAt     DateTime?
  resolvedBy     String?
  metadata       Json?
  service        BigDataService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([status])
  @@index([severity])
  @@map("service_alerts")
}

model AirflowDag {
  id           String    @id @default(cuid())
  dagId        String    @unique
  dagName      String
  description  String?
  status       DagStatus
  isPaused     Boolean   @default(false)
  lastRunTime  DateTime?
  nextRunTime  DateTime?
  successCount Int       @default(0)
  failedCount  Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  runs         DagRun[]

  @@index([dagId])
  @@index([status])
  @@map("airflow_dags")
}

model DagRun {
  id        String     @id @default(cuid())
  dagId     String
  runId     String     @unique
  status    DagStatus
  startDate DateTime
  endDate   DateTime?
  duration  Float?
  logUrl    String?
  metadata  Json?
  dag       AirflowDag @relation(fields: [dagId], references: [id], onDelete: Cascade)

  @@index([dagId])
  @@index([status])
  @@index([startDate])
  @@map("dag_runs")
}

model SystemLog {
  id          String      @id @default(cuid())
  userId      String?
  level       LogLevel
  category    LogCategory
  action      String
  description String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())
  user        User?       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([level])
  @@index([category])
  @@index([createdAt])
  @@map("system_logs")
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  action    String
  resource  String?
  details   String?
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
  @@map("user_activities")
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  category    String
  description String?
  isEditable  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([category])
  @@map("system_configs")
}

model ResearchFile {
  id               String              @id @default(cuid())
  fileName         String
  originalName     String
  fileSize         Int
  fileType         FileType
  mimeType         String
  bucketName       String
  objectKey        String
  fileUrl          String?
  uploadedBy       String
  department       String?
  researchArea     String?
  tags             String[]
  status           FileStatus          @default(UPLOADING)
  title            String?
  description      String?
  keywords         String[]
  downloadCount    Int                 @default(0)
  viewCount        Int                 @default(0)
  uploadedAt       DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  checksum         String?
  classification   ClassificationLevel @default(INTERNAL)
  digitalSignature String?
  isLatest         Boolean             @default(true)
  parentId         String?
  version          Int                 @default(1)
  accessLogs       FileAccessLog[]

  @@index([uploadedBy])
  @@index([fileType])
  @@index([department])
  @@index([status])
  @@index([classification])
  @@index([parentId])
  @@index([uploadedAt])
  @@map("research_files")
}

model FileAccessLog {
  id           String       @id @default(cuid())
  fileId       String
  userId       String
  action       AccessAction
  ipAddress    String?
  userAgent    String?
  location     String?
  success      Boolean      @default(true)
  errorMessage String?
  metadata     Json?
  timestamp    DateTime     @default(now())
  file         ResearchFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([userId])
  @@index([action])
  @@index([timestamp])
  @@map("file_access_logs")
}

model DataQuery {
  id            String      @id @default(cuid())
  queryText     String
  queryType     QueryType
  executedBy    String
  department    String?
  status        QueryStatus @default(PENDING)
  executionTime Float?
  rowsReturned  Int?
  dataSize      Float?
  resultUrl     String?
  errorMessage  String?
  parameters    Json?
  submittedAt   DateTime    @default(now())
  startedAt     DateTime?
  completedAt   DateTime?

  @@index([executedBy])
  @@index([queryType])
  @@index([status])
  @@index([submittedAt])
  @@map("data_queries")
}

model AnalyticsSummary {
  id              String   @id @default(cuid())
  summaryType     String
  summaryDate     DateTime
  totalUsers      Int
  activeUsers     Int
  newUsers        Int
  totalServices   Int
  healthyServices Int
  downServices    Int
  totalFiles      Int
  totalQueries    Int
  totalStorage    Float
  dataUploaded    Float
  queriesExecuted Int
  avgQueryTime    Float
  avgCpuUsage     Float
  avgMemoryUsage  Float
  avgDiskUsage    Float
  metadata        Json?
  createdAt       DateTime @default(now())

  @@unique([summaryType, summaryDate])
  @@index([summaryType])
  @@index([summaryDate])
  @@map("analytics_summaries")
}

model MLModel {
  id                  String              @id @default(cuid())
  name                String
  description         String?
  modelType           ModelType
  framework           ModelFramework
  ownerId             String
  department          String?
  researchArea        String?
  classification      ClassificationLevel @default(INTERNAL)
  trainingDatasetId   String?
  validationDatasetId String?
  version             String              @default("1.0.0")
  parentId            String?
  isLatest            Boolean             @default(true)
  bucketName          String?
  modelPath           String?
  configPath          String?
  hyperparameters     Json?
  trainingConfig      Json?
  accuracy            Float?
  precision           Float?
  recall              Float?
  f1Score             Float?
  loss                Float?
  customMetrics       Json?
  status              ModelStatus         @default(DRAFT)
  trainingStartedAt   DateTime?
  trainingCompletedAt DateTime?
  trainingDuration    Float?
  deployedAt          DateTime?
  deploymentUrl       String?
  predictionCount     Int                 @default(0)
  tags                String[]
  metadata            Json?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  predictions         ModelPrediction[]
  trainingJobs        TrainingJob[]

  @@index([ownerId])
  @@index([modelType])
  @@index([framework])
  @@index([status])
  @@index([classification])
  @@index([createdAt])
  @@map("ml_models")
}

model TrainingJob {
  id                String    @id @default(cuid())
  modelId           String
  jobName           String
  jobType           String    @default("training")
  config            Json?
  hyperparameters   Json?
  trainingDataset   String?
  validationDataset String?
  testDataset       String?
  status            JobStatus @default(QUEUED)
  gpuAllocated      Int?
  cpuAllocated      Int?
  memoryAllocated   Float?
  progress          Float     @default(0)
  currentEpoch      Int?
  totalEpochs       Int?
  startedAt         DateTime?
  completedAt       DateTime?
  duration          Float?
  finalMetrics      Json?
  logPath           String?
  errorMessage      String?
  errorStack        String?
  retryCount        Int       @default(0)
  maxRetries        Int       @default(3)
  metadata          Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  model             MLModel   @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@index([status])
  @@index([startedAt])
  @@map("training_jobs")
}

model ModelPrediction {
  id            String   @id @default(cuid())
  modelId       String
  userId        String?
  inputData     Json
  outputData    Json
  inferenceTime Float
  feedback      String?
  isCorrect     Boolean?
  timestamp     DateTime @default(now())
  model         MLModel  @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@index([userId])
  @@index([timestamp])
  @@map("model_predictions")
}

model DataPipeline {
  id               String         @id @default(cuid())
  name             String
  description      String?
  pipelineType     String
  inputDataset     String
  outputDataset    String?
  steps            Json
  parameters       Json?
  status           PipelineStatus @default(PENDING)
  startedAt        DateTime?
  completedAt      DateTime?
  duration         Float?
  recordsProcessed Int?
  errorCount       Int?
  logPath          String?
  errorMessage     String?
  createdBy        String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([status])
  @@index([createdBy])
  @@index([createdAt])
  @@map("data_pipelines")
}

model experiment_artifacts {
  id            String    @id @db.VarChar(255)
  experiment_id String    @db.VarChar(255)
  artifact_name String    @db.VarChar(255)
  artifact_type String?   @db.VarChar(50)
  artifact_path String?
  file_size     BigInt?
  created_at    DateTime? @default(now()) @db.Timestamp(6)

  @@index([experiment_id], map: "idx_artifacts_experiment")
}

model experiment_metrics {
  id            String    @id @db.VarChar(255)
  experiment_id String    @db.VarChar(255)
  metric_name   String    @db.VarChar(255)
  metric_value  Float
  step          Int?      @default(0)
  epoch         Int?      @default(0)
  timestamp     DateTime? @default(now()) @db.Timestamp(6)

  @@index([experiment_id], map: "idx_metrics_experiment")
  @@index([metric_name], map: "idx_metrics_name")
}

model ml_experiments {
  id          String    @id @db.VarChar(255)
  name        String    @db.VarChar(255)
  description String?
  model_id    String?   @db.VarChar(255)
  parameters  Json?     @default("{}")
  tags        Json?     @default("[]")
  status      String?   @default("pending") @db.VarChar(50)
  results     Json?     @default("{}")
  start_time  DateTime? @db.Timestamp(6)
  end_time    DateTime? @db.Timestamp(6)
  created_by  String?   @db.VarChar(255)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)

  @@index([created_at], map: "idx_experiments_created")
  @@index([model_id], map: "idx_experiments_model")
  @@index([status], map: "idx_experiments_status")
}

model ml_workflows {
  id          String    @id @db.VarChar(255)
  name        String    @db.VarChar(255)
  description String?
  model_id    String?   @db.VarChar(255)
  steps       Json?     @default("[]")
  schedule    Json?     @default("{}")
  parameters  Json?     @default("{}")
  status      String?   @default("draft") @db.VarChar(50)
  created_by  String?   @db.VarChar(255)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)

  @@index([model_id], map: "idx_workflows_model")
  @@index([status], map: "idx_workflows_status")
}

model model_versions {
  id             String    @id @db.VarChar(255)
  model_id       String    @db.VarChar(255)
  version_number Int
  description    String?
  experiment_id  String?   @db.VarChar(255)
  metrics        Json?     @default("{}")
  artifact_path  String?
  tags           Json?     @default("[]")
  stage          String?   @default("development") @db.VarChar(50)
  status         String?   @default("draft") @db.VarChar(50)
  notes          String?
  created_by     String?   @db.VarChar(255)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)

  @@unique([model_id, version_number])
  @@index([created_at], map: "idx_versions_created")
  @@index([model_id], map: "idx_versions_model")
  @@index([stage], map: "idx_versions_stage")
}

model workflow_executions {
  id           String    @id @db.VarChar(255)
  workflow_id  String    @db.VarChar(255)
  status       String?   @default("pending") @db.VarChar(50)
  parameters   Json?     @default("{}")
  current_step Int?      @default(0)
  progress     Int?      @default(0)
  results      Json?     @default("{}")
  error        String?
  started_at   DateTime? @db.Timestamp(6)
  completed_at DateTime? @db.Timestamp(6)
  started_by   String?   @db.VarChar(255)

  @@index([status], map: "idx_executions_status")
  @@index([workflow_id], map: "idx_executions_workflow")
}

model Unit {
  id               String              @id @default(cuid())
  name             String
  code             String              @unique
  type             String
  level            Int
  parentId         String?
  commanderId      String?
  description      String?
  active           Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  path             String?
  facultyProfiles  FacultyProfile[]    @relation("FacultyProfileUnit")
  personnelMembers Personnel[]         @relation("PersonnelUnit")
  positionAliases  UnitPositionAlias[] @relation("UnitPositionAliases")
  commander        User?               @relation("UnitCommander", fields: [commanderId], references: [id])
  parent           Unit?               @relation("UnitHierarchy", fields: [parentId], references: [id])
  children         Unit[]              @relation("UnitHierarchy")
  userPositions    UserPosition[]      @relation("UserPositionUnit")
  users            User[]

  @@index([code])
  @@index([type])
  @@index([parentId])
  @@index([commanderId])
  @@index([path])
  @@map("units")
}

model PersonnelAttachment {
  id          String         @id @default(cuid())
  userId      String
  fileName    String
  fileUrl     String
  fileSize    Int?
  fileType    AttachmentType
  mimeType    String?
  description String?
  uploadedAt  DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  isPublic    Boolean        @default(false)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([fileType])
  @@map("personnel_attachments")
}

model TeachingSubject {
  id           String         @id @default(cuid())
  facultyId    String
  subjectName  String
  subjectCode  String?
  credits      Int            @default(0)
  semester     String?
  academicYear String?
  department   String?
  description  String?
  syllabus     String?
  studentCount Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  faculty      FacultyProfile @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@index([facultyId])
  @@index([academicYear])
}

model ResearchProject {
  id             String                 @id @default(cuid())
  facultyId      String
  projectName    String
  projectCode    String?
  field          String?
  level          String?
  fundingAmount  Float                  @default(0)
  startYear      String?
  endYear        String?
  status         String                 @default("Đang thực hiện")
  description    String?
  outcomes       String?
  publications   Int                    @default(0)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  approvedAt     DateTime?
  approvedBy     String?
  approverNote   String?
  completedAt    DateTime?
  completedBy    String?
  rejectReason   String?
  reviewedAt     DateTime?
  reviewedBy     String?
  reviewerNote   String?
  submittedAt    DateTime?
  submittedBy    String?
  workflowStatus ResearchWorkflowStatus @default(DRAFT)
  faculty        FacultyProfile         @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@index([facultyId])
  @@index([status])
  @@index([level])
  @@index([workflowStatus])
}

model HocVien {
  id                  String          @id @default(cuid())
  maHocVien           String          @unique
  hoTen               String
  ngaySinh            DateTime?
  gioiTinh            String?
  lop                 String?
  khoaHoc             String?
  nganh               String?
  giangVienHuongDanId String?
  email               String?
  dienThoai           String?
  diaChi              String?
  diemTrungBinh       Float           @default(0)
  trangThai           String          @default("Đang học")
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  giangVienHuongDan   FacultyProfile? @relation(fields: [giangVienHuongDanId], references: [id])
  ketQuaHocTap        KetQuaHocTap[]
  registrations       Registration[]

  @@index([maHocVien])
  @@index([lop])
  @@index([khoaHoc])
  @@index([nganh])
  @@index([giangVienHuongDanId])
  @@map("hoc_vien")
}

model KetQuaHocTap {
  id             String              @id @default(cuid())
  hocVienId      String
  monHoc         String
  maMon          String?
  diem           Float?
  diemQuaTrinh   Float?
  diemThi        Float?
  hocKy          String?
  namHoc         String?
  ketQua         String?
  xepLoai        String?
  nhanXet        String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  diemBaiTap     Float?
  diemChuyenCan  Float?
  diemGiuaKy     Float?
  diemTongKet    Float?
  giangVienId    String?
  heSoMonHocId   String?
  soTinChi       Int                 @default(3)
  approvedAt     DateTime?
  approvedBy     String?
